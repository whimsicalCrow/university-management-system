@page "/meetings"

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2"><span class="bi bi-calendar-event"></span> Meetings</span>
            <h1 class="section-heading mb-2">Meetings &amp; Scheduling</h1>
            <p class="text-muted mb-0">Συντονίστε συναντήσεις, οριστικοποιήστε agendas και παρακολουθήστε τα follow-up tasks.</p>
        </div>
        <NavLink class="btn btn-primary mt-3 mt-lg-0" href="meetings">Νέα πρόσκληση</NavLink>
    </div>

    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">Upcoming Meetings</h2>
        <div class="card info-card">
            <div class="card-body">
                <p class="text-muted mb-0">Calendared sessions and confirmation states will appear in this list.</p>
            </div>
        </div>
    </section>

    <section>
        <h2 class="h4 fw-semibold mb-3">Schedule a Meeting</h2>
        <div class="card info-card">
            <div class="card-body">
                <p class="text-muted mb-0">A scheduling form with availability selection will be introduced in the next iterations.</p>
            </div>
        </div>
    </section>
</div>
