@page "/"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using University.Domain.Enums
@inject UserSessionService Session
@inject NavigationManager Nav
@inject University.Infrastructure.Data.UniversityDbContext Db
@inject IThesisNotificationService NotifService

@if (!_sessionReady)
{
    <div class="container page-section">
        <div class="card info-card">
            <div class="card-body">
                <p class="mb-0 text-muted">Φόρτωση...</p>
            </div>
        </div>
    </div>
}
else if (Session.Role == UserRole.Professor)
{
<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2"><span class="bi bi-mortarboard-fill"></span> Αρχική Καθηγητή</span>
            <h1 class="section-heading mb-2">Καλώς ήρθατε στο Σύστημα Διαχείρισης Διπλωματικών Εργασιών |</h1>
            <p class="text-muted mb-0">Επισκεφθείτε τις προτεραιότητες, διαχειριστείτε θέματα και συντονίστε συναντήσεις με φοιτητές.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-lg-0">
            <NavLink class="btn btn-primary" href="thesis-topics">Διαχείριση Θεμάτων</NavLink>
            <NavLink class="btn btn-outline-secondary" href="meetings">Επερχόμενες Συναντήσεις</NavLink>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @if (_isLoadingMetrics)
        {
            <div class="col-12">
                <div class="card info-card">
                    <div class="card-body text-muted">Φόρτωση μετρικών...</div>
                </div>
            </div>
        }
        else
        {
            <div class="col-md-4 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_activeSupervisions</div>
                    <div class="metric-label">Ενεργές Διπλωματικές</div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_pendingReviews</div>
                    <div class="metric-label">Εκκρεμείς Αξιολογήσεις</div>
                </div>
            </div>
            <div class="col-md-4 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_upcomingMeetings</div>
                    <div class="metric-label">Επερχόμενες Συναντήσεις</div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card info-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">Σήμερα</h2>
                    <p class="mb-0 text-muted">Δεν υπάρχουν εργασίες σήμερα.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card info-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">Γρήγορη Πλοήγηση</h2>
                    <div class="d-flex flex-column gap-2">
                        <NavLink class="btn btn-outline-primary text-start" href="thesis-topics">Θέματα Διπλωματικής</NavLink>
                        <NavLink class="btn btn-outline-primary text-start" href="updates">Ενημερώσεις</NavLink>
                        <NavLink class="btn btn-outline-primary text-start" href="meetings">Ημερολόγιο Συναντήσεων</NavLink>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_notifications.Count > 0)
    {
        <div class="row g-4 mt-0">
            <div class="col-12">
                <div class="card info-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h2 class="h5 fw-semibold mb-0">
                                <span class="bi bi-bell-fill me-2 text-warning"></span>Εκδηλώσεις Ενδιαφέροντος
                                @if (_notifications.Any(n => !n.IsRead))
                                {
                                    <span class="badge bg-danger ms-2">@_notifications.Count(n => !n.IsRead) νέα</span>
                                }
                            </h2>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="MarkAllReadAsync">Σήμανση ως αναγνωσμένα</button>
                        </div>
                        <ul class="list-group list-group-flush">
                            @foreach (var n in _notifications.Take(10))
                            {
                                <li class="list-group-item px-0 @(!n.IsRead ? "fw-semibold" : "")">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            @if (!n.IsRead)
                                            {
                                                <span class="badge bg-warning text-dark me-2">Νέο</span>
                                            }
                                            <span class="bi bi-person-fill me-1 text-muted"></span>
                                            <span>@n.StudentEmail</span>
                                            <span class="text-muted ms-1">εκδήλωσε ενδιαφέρον για το θέμα</span>
                                            <strong class="ms-1">&ldquo;@n.TopicTitle&rdquo;</strong>
                                        </div>
                                        <small class="text-muted text-nowrap">@n.At.ToLocalTime().ToString("dd/MM HH:mm")</small>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
}

@code {
    private bool _sessionReady = false;
    private bool _isLoadingMetrics = true;
    private int _activeSupervisions;
    private int _pendingReviews;
    private int _upcomingMeetings;
    private List<ThesisInterestNotification> _notifications = new();

    protected override async Task OnInitializedAsync()
    {
        if (Session.Role == UserRole.Student)
        {
            _sessionReady = true;
            return;
        }

        _sessionReady = true;

        if (Session.Role == UserRole.Professor)
        {
            await LoadProfessorMetricsAsync();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && Session.Role == UserRole.Student)
            Nav.NavigateTo("/dashboard", forceLoad: false);
    }

    private async Task LoadProfessorMetricsAsync()
    {
        var email = (Session.UserName ?? string.Empty).Trim().ToUpperInvariant();

        var userId = await Db.Users
            .AsNoTracking()
            .Where(u => u.NormalizedEmail == email || u.NormalizedUserName == email)
            .Select(u => u.Id)
            .FirstOrDefaultAsync();

        if (userId is null)
        {
            _isLoadingMetrics = false;
            return;
        }

        var professorId = await Db.Professors
            .AsNoTracking()
            .Where(p => p.UserId == userId)
            .Select(p => (int?)p.Id)
            .FirstOrDefaultAsync();

        if (professorId is null)
        {
            _isLoadingMetrics = false;
            return;
        }

        _activeSupervisions = await Db.ThesisTopicAssignments
            .AsNoTracking()
            .CountAsync(a => a.ProfessorId == professorId.Value);

        var supervisedStudentIds = await Db.ThesisTopicAssignments
            .AsNoTracking()
            .Where(a => a.ProfessorId == professorId.Value)
            .Select(a => a.StudentId)
            .ToListAsync();

        _pendingReviews = await Db.ThesisUpdates
            .AsNoTracking()
            .CountAsync(tu => supervisedStudentIds.Contains(tu.StudentId)
                              && tu.Status == UpdateStatus.Submitted);

        // No Meetings table in domain model yet.
        _upcomingMeetings = 0;

        _notifications = (await NotifService.GetForProfessorAsync(Session.UserName!)).ToList();

        _isLoadingMetrics = false;
    }

    private async Task MarkAllReadAsync()
    {
        await NotifService.MarkAllReadAsync(Session.UserName!);
        _notifications = (await NotifService.GetForProfessorAsync(Session.UserName!)).ToList();
    }
}

