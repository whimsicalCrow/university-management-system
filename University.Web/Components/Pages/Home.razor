@page "/"
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using University.Domain.Enums
@inject UserSessionService Session
@inject NavigationManager Nav
@inject University.Infrastructure.Data.UniversityDbContext Db

@if (!_sessionReady)
{
    <div class="container page-section">
        <div class="card info-card">
            <div class="card-body">
                <p class="mb-0 text-muted">Loading...</p>
            </div>
        </div>
    </div>
}
else if (Session.Role == UserRole.Professor)
{
<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2"><span class="bi bi-mortarboard-fill"></span> Professor Home</span>
            <h1 class="section-heading mb-2">Welcome to Thesis Collaboration</h1>
            <p class="text-muted mb-0">Quickly review priorities, manage topics, and coordinate meetings with students.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-lg-0">
            <NavLink class="btn btn-primary" href="thesis-topics">Manage Topics</NavLink>
            <NavLink class="btn btn-outline-secondary" href="meetings">Upcoming Meetings</NavLink>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @if (_isLoadingMetrics)
        {
            <div class="col-12">
                <div class="card info-card">
                    <div class="card-body text-muted">Loading metrics...</div>
                </div>
            </div>
        }
        else
        {
            <div class="col-md-3 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_activeSupervisions</div>
                    <div class="metric-label">Active Supervisions</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_pendingReviews</div>
                    <div class="metric-label">Pending Reviews</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_upcomingMeetings</div>
                    <div class="metric-label">Upcoming Meetings</div>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="metric-card">
                    <div class="metric-value">@_reservationRequests</div>
                    <div class="metric-label">Reservation Requests</div>
                </div>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card info-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">Today</h2>
                    <p class="mb-0 text-muted">No tasks today.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card info-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">Quick Navigation</h2>
                    <div class="d-flex flex-column gap-2">
                        <NavLink class="btn btn-outline-primary text-start" href="thesis-topics">Thesis Topics</NavLink>
                        <NavLink class="btn btn-outline-primary text-start" href="updates">Thesis Updates</NavLink>
                        <NavLink class="btn btn-outline-primary text-start" href="meetings">Meetings Calendar</NavLink>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    private bool _sessionReady = false;
    private bool _isLoadingMetrics = true;
    private int _activeSupervisions;
    private int _pendingReviews;
    private int _upcomingMeetings;
    private int _reservationRequests;

    protected override async Task OnInitializedAsync()
    {
        if (Session.Role == UserRole.Student)
        {
            _sessionReady = true;
            return;
        }

        _sessionReady = true;

        if (Session.Role == UserRole.Professor)
        {
            await LoadProfessorMetricsAsync();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && Session.Role == UserRole.Student)
            Nav.NavigateTo("/dashboard", forceLoad: false);
    }

    private async Task LoadProfessorMetricsAsync()
    {
        var email = (Session.UserName ?? string.Empty).Trim().ToUpperInvariant();

        var userId = await Db.Users
            .AsNoTracking()
            .Where(u => u.NormalizedEmail == email || u.NormalizedUserName == email)
            .Select(u => u.Id)
            .FirstOrDefaultAsync();

        if (userId is null)
        {
            _isLoadingMetrics = false;
            return;
        }

        var professorId = await Db.Professors
            .AsNoTracking()
            .Where(p => p.UserId == userId)
            .Select(p => (int?)p.Id)
            .FirstOrDefaultAsync();

        if (professorId is null)
        {
            _isLoadingMetrics = false;
            return;
        }

        _activeSupervisions = await Db.ThesisTopicAssignments
            .AsNoTracking()
            .CountAsync(a => a.ProfessorId == professorId.Value);

        var supervisedStudentIds = await Db.ThesisTopicAssignments
            .AsNoTracking()
            .Where(a => a.ProfessorId == professorId.Value)
            .Select(a => a.StudentId)
            .ToListAsync();

        _pendingReviews = await Db.ThesisUpdates
            .AsNoTracking()
            .CountAsync(tu => supervisedStudentIds.Contains(tu.StudentId)
                              && tu.Status == UpdateStatus.Submitted);

        // No Meetings or ReservationRequests tables in domain model yet.
        _upcomingMeetings = 0;
        _reservationRequests = 0;

        _isLoadingMetrics = false;
    }
}

