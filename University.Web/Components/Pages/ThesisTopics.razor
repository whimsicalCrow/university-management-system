    private async Task LoadProfessorOptionsAsync()
    {
        var emails = await TopicAssignmentService.GetAllProfessorEmailsAsync();
        var emailToName = _professorNameToAccount
            .Where(kvp => !string.IsNullOrEmpty(kvp.Value))
            .GroupBy(kvp => kvp.Value, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().Key, StringComparer.OrdinalIgnoreCase);
        _professorOptions = emails
            .Select(e => (
                DisplayName: emailToName.TryGetValue(e, out var name) ? name : e,
                Email: e))
            .OrderBy(o => o.DisplayName)
            .ToList();
    }

