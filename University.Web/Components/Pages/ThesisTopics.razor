@page "/thesis-topics"
@attribute [Authorize]
@inject UserSessionService Session
@inject IThesisInterestService InterestService
@inject IThesisTopicAssignmentService TopicAssignmentService

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2">
                <span class="bi bi-lightbulb-fill"></span>
                @(Session.Role == UserRole.Professor ? "Professor View" : "Student View")
            </span>
            <h1 class="section-heading mb-2">Thesis Topics</h1>
            <p class="text-muted mb-0">
                @if (Session.Role == UserRole.Professor)
                {
                    <span>Public topics are visible to everyone. You can manage your own draft and ongoing topics.</span>
                }
                else
                {
                    <span>You can browse public topics, express interest, and access only the ongoing topic assigned to you.</span>
                }
            </p>
        </div>
        <button class="btn btn-primary mt-3 mt-lg-0" @onclick="OpenProposalForm">
            <span class="bi bi-plus-lg me-1"></span>
            @(Session.Role == UserRole.Professor ? "Propose New Topic" : "Suggest a Topic")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <span class="bi bi-check-circle-fill me-2"></span>@_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            <span class="bi bi-exclamation-circle-fill me-2"></span>@_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (_showForm)
    {
        <div class="card info-card mb-5">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="h5 fw-semibold mb-0">
                        @(_editingId.HasValue ? "Edit Topic" : "Propose a Topic")
                    </h2>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelForm">
                        <span class="bi bi-x-lg"></span> Cancel
                    </button>
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
                        <input class="form-control @(_formErrors.ContainsKey("Title") ? "is-invalid" : "")"
                               placeholder="e.g. Machine Learning for Smart Grid Optimisation"
                               @bind="_form.Title" @bind:event="oninput" />
                        @if (_formErrors.TryGetValue("Title", out var titleErr))
                        {
                            <div class="invalid-feedback">@titleErr</div>
                        }
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                        <textarea class="form-control @(_formErrors.ContainsKey("Description") ? "is-invalid" : "")"
                                  rows="4"
                                  placeholder="Summarise the research area, objectives, and expected outcomes..."
                                  @bind="_form.Description" @bind:event="oninput"></textarea>
                        @if (_formErrors.TryGetValue("Description", out var descErr))
                        {
                            <div class="invalid-feedback">@descErr</div>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Research Area</label>
                        <select class="form-select" @bind="_form.Area">
                            <option value="">- Select area -</option>
                            @foreach (var area in ResearchAreas)
                            {
                                <option value="@area">@area</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Supervising Professor <span class="text-danger">*</span></label>
                        <select class="form-select @(_formErrors.ContainsKey("SupervisingProfessor") ? "is-invalid" : "")"
                                @bind="_form.SupervisingProfessor">
                            <option value="">- Select professor -</option>
                            @foreach (var opt in _professorOptions)
                            {
                                <option value="@opt.DisplayName">@opt.DisplayName</option>
                            }
                        </select>
                        @if (_formErrors.TryGetValue("SupervisingProfessor", out var profErr))
                        {
                            <div class="invalid-feedback">@profErr</div>
                        }
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Prerequisites</label>
                        <input class="form-control"
                               placeholder="e.g. Linear Algebra, Python"
                               @bind="_form.Prerequisites" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Max Students</label>
                        <input type="number" min="1" max="10" class="form-control" @bind="_form.MaxStudents" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary" @onclick="SubmitForm">
                        <span class="bi bi-save me-1"></span>
                        @(_editingId.HasValue ? "Save Changes" : "Save as Draft")
                    </button>
                    @if (!_editingId.HasValue && Session.Role == UserRole.Professor)
                    {
                        <button class="btn btn-outline-success" @onclick="SaveAndOpen">
                            <span class="bi bi-unlock me-1"></span> Save as Open
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    <div class="card info-card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-lg-4">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <span class="bi bi-search text-muted"></span>
                        </span>
                        <input class="form-control border-start-0"
                               placeholder="Title, keyword, professor..."
                               @bind="_searchText" @bind:event="oninput" />
                    </div>
                </div>

                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Status</label>
                    <select class="form-select" @bind="_filterStatus">
                        <option value="">All statuses</option>
                        @foreach (var s in TopicStatuses)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>

                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-semibold text-uppercase text-muted">Area</label>
                    <select class="form-select" @bind="_filterArea">
                        <option value="">All areas</option>
                        @foreach (var a in ResearchAreas)
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>

                <div class="col-lg-4 col-md-4 text-md-end">
                    <button class="btn btn-outline-secondary w-100" @onclick="ClearFilters">
                        <span class="bi bi-x-circle me-1"></span> Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <span class="text-muted small">
            Showing <strong>@FilteredTopics.Count()</strong> of <strong>@_topics.Count</strong> topics
        </span>
        <div class="d-flex gap-2 align-items-center">
            <span class="small text-muted">Sort:</span>
            <select class="form-select form-select-sm" style="width:auto;" @bind="_sortOrder">
                <option value="Newest">Newest first</option>
                <option value="Oldest">Oldest first</option>
                <option value="Title">Title A-Z</option>
                <option value="Status">Status</option>
            </select>
        </div>
    </div>

    @{
        var displayed = FilteredTopics.ToList();
    }

    @if (displayed.Count == 0)
    {
        <div class="card info-card">
            <div class="card-body text-center text-muted py-5">
                <span class="bi bi-search mb-3" style="font-size:2.5rem; display:block; opacity:.4;"></span>
                <p class="mb-0">No topics match your current filters.</p>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var topic in displayed)
            {
                <div class="card topic-card @(topic.Status == TopicStatus.Draft ? "topic-draft" : "")">
                    <div class="card-body p-4">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div class="flex-fill">
                                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                    <span class="@StatusBadgeClass(topic.Status)">@topic.Status</span>
                                    @if (!string.IsNullOrWhiteSpace(topic.Area))
                                    {
                                        <span class="badge bg-light text-dark border">@topic.Area</span>
                                    }
                                    <span class="text-muted small ms-auto">
                                        <span class="bi bi-person-circle me-1"></span>@topic.ProposedBy
                                        &nbsp;-&nbsp;
                                        @topic.ProposedOn.ToString("dd MMM yyyy")
                                    </span>
                                </div>

                                <h3 class="h5 fw-semibold mb-2 topic-title">@topic.Title</h3>
                                <p class="text-muted mb-3 topic-description">@topic.Description</p>

                                @if (!string.IsNullOrWhiteSpace(topic.Prerequisites))
                                {
                                    <p class="mb-2 small">
                                        <span class="bi bi-journal-check me-1 text-muted"></span>
                                        <strong>Prerequisites:</strong> @topic.Prerequisites
                                    </p>
                                }

                                <p class="mb-2 small text-muted">
                                    <span class="bi bi-person-workspace me-1"></span>
                                    <strong>Supervising Professor:</strong> @topic.SupervisingProfessor
                                </p>

                                @if (!string.IsNullOrWhiteSpace(topic.AssignedStudentAccount) && topic.Status == TopicStatus.Ongoing)
                                {
                                    <p class="mb-2 small text-muted">
                                        <span class="bi bi-person-check me-1"></span>
                                        <strong>Assigned Student:</strong> @topic.AssignedStudentAccount
                                    </p>
                                }

                                @if (Session.Role == UserRole.Professor && IsCurrentProfessorInCharge(topic) && topic.Status == TopicStatus.Open)
                                {
                                    <div class="mt-3">
                                        <p class="mb-2 small text-muted fw-semibold text-uppercase">Interested students</p>
                                        @if (topic.InterestedStudents.Count == 0)
                                        {
                                            <p class="mb-0 small text-muted">No student interest yet.</p>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column gap-2">
                                                @foreach (var interest in topic.InterestedStudents.OrderByDescending(i => i.ExpressedOn))
                                                {
                                                    <div class="d-flex flex-wrap align-items-center gap-2">
                                                        <span class="badge bg-light text-dark border">@interest.StudentEmail</span>
                                                        <span class="small text-muted">@interest.ExpressedOn.ToString("dd MMM yyyy HH:mm")</span>
                                                        <button class="btn btn-outline-primary btn-sm"
                                                                @onclick="() => AssignInterestedStudentAsync(topic.Id, interest.StudentEmail)"
                                                                disabled="@_topicActionInProgressIds.Contains(topic.Id)">
                                                            <span class="bi bi-person-check me-1"></span> Assign Student
                                                        </button>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        <div class="mt-3 pt-3 border-top">
                                            <p class="mb-2 small text-muted fw-semibold text-uppercase">Direct assign</p>
                                            <div class="d-flex gap-2 align-items-center">
                                                <input class="form-control form-control-sm"
                                                       placeholder="Student email address..."
                                                       value="@(_directAssignEmails.GetValueOrDefault(topic.Id, string.Empty))"
                                                       @oninput="args => _directAssignEmails[topic.Id] = args.Value?.ToString() ?? string.Empty"
                                                       disabled="@_topicActionInProgressIds.Contains(topic.Id)" />
                                                <button class="btn btn-outline-primary btn-sm flex-shrink-0"
                                                        @onclick="() => DirectAssignStudentAsync(topic.Id)"
                                                        disabled="@_topicActionInProgressIds.Contains(topic.Id)">
                                                    <span class="bi bi-person-check me-1"></span> Assign
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }

                                <span class="small text-muted">
                                    <span class="bi bi-people me-1"></span>Max @topic.MaxStudents student@(topic.MaxStudents != 1 ? "s" : "")
                                </span>
                            </div>

                            <div class="d-flex flex-lg-column gap-2 flex-shrink-0 align-self-start">
                                @if (Session.Role == UserRole.Professor)
                                {
                                    @if (IsCurrentProfessorInCharge(topic) && (topic.Status == TopicStatus.Draft || topic.Status == TopicStatus.Open))
                                    {
                                        <button class="btn btn-outline-primary btn-sm" @onclick="() => EditTopic(topic)">
                                            <span class="bi bi-pencil me-1"></span> Edit
                                        </button>
                                    }
                                    @if (IsCurrentProfessorInCharge(topic) && topic.Status == TopicStatus.Draft)
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => PublishTopic(topic.Id)">
                                            <span class="bi bi-unlock me-1"></span> Publish Open
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDraft(topic.Id)">
                                            <span class="bi bi-trash me-1"></span> Delete
                                        </button>
                                    }
                                    @if (IsCurrentProfessorInCharge(topic) && (topic.Status == TopicStatus.Open || topic.Status == TopicStatus.Ongoing))
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => ArchiveTopic(topic.Id)">
                                            <span class="bi bi-archive me-1"></span> Archive
                                        </button>
                                    }
                                    @if (IsCurrentProfessorInCharge(topic) && topic.Status == TopicStatus.Open)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => DeleteOpenTopicAsync(topic.Id)"
                                                disabled="@_topicActionInProgressIds.Contains(topic.Id)">
                                            <span class="bi bi-trash me-1"></span> Delete
                                        </button>
                                    }
                                    @if (IsCurrentProfessorInCharge(topic) && topic.Status == TopicStatus.Ongoing)
                                    {
                                        <button class="btn btn-outline-danger btn-sm"
                                                @onclick="() => RemoveAssignedStudentAsync(topic.Id)"
                                                disabled="@_topicActionInProgressIds.Contains(topic.Id)">
                                            <span class="bi bi-person-x me-1"></span> Remove Student
                                        </button>
                                    }
                                }
                                else
                                {
                                    @if (topic.Status == TopicStatus.Open)
                                    {
                                        <button class="btn btn-outline-success btn-sm" @onclick="() => ExpressInterestAsync(topic.Id)" disabled="@_topicActionInProgressIds.Contains(topic.Id) || HasCurrentStudentExpressedInterest(topic)">
                                            <span class="bi bi-heart me-1"></span> Express Interest
                                        </button>
                                    }
                                    @if (topic.Status == TopicStatus.Open && HasCurrentStudentExpressedInterest(topic))
                                    {
                                        <button class="btn btn-success btn-sm" disabled>
                                            <span class="bi bi-heart-fill me-1"></span> Interest Registered
                                        </button>
                                    }
                                    @if (topic.Status == TopicStatus.Ongoing && IsCurrentStudentAssigned(topic))
                                    {
                                        <button class="btn btn-success btn-sm" disabled>
                                            <span class="bi bi-check-circle me-1"></span> Assigned to You
                                        </button>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private static class TopicStatus
    {
        public const string Draft = "Draft";
        public const string Open = "Open";
        public const string Ongoing = "Ongoing";
        public const string Archived = "Archived";
    }

    private static readonly Guid TopicIdFederatedLearning = Guid.Parse("2bf2d9c6-6f54-4f4f-8c10-5f765b114001");
    private static readonly Guid TopicIdNetworkSlicing = Guid.Parse("2bf2d9c6-6f54-4f4f-8c10-5f765b114002");
    private static readonly Guid TopicIdSmartGrid = Guid.Parse("2bf2d9c6-6f54-4f4f-8c10-5f765b114003");
    private static readonly Guid TopicIdExplainability = Guid.Parse("2bf2d9c6-6f54-4f4f-8c10-5f765b114004");

    private static readonly string[] TopicStatuses =
    {
        TopicStatus.Draft,
        TopicStatus.Open,
        TopicStatus.Ongoing,
        TopicStatus.Archived,
    };

    private static readonly string[] ResearchAreas =
    {
        "Ενεργειακών Συστημάτων",
        "Σημάτων, Τηλεπικοινωνιών και Δικτύων",
        "Ηλεκτρονικής, Υπολογιστών και Συστημάτων",
        "Πληροφορικής",
    };

    // Maps display name → demo account (pages 30-38 of the department curriculum document)
    private readonly Dictionary<string, string> _professorNameToAccount = new(StringComparer.OrdinalIgnoreCase)
    {
        // ── Demo accounts ──────────────────────────────────────────────────────────
        ["Καθ. Βλαχόπουλος"]   = "prof1@univ.edu",   // Βλαχόπουλος Πέτρος
        ["Αναπλ. Παρασκευάς"]  = "prof2@univ.edu",   // Παρασκευάς Μιχαήλ
        ["Καθ. Ταμπακάς"]      = "prof3@univ.edu",   // Ταμπακάς Βασίλειος
        ["Αναπλ. Κίτσος"]      = "prof4@univ.edu",   // Κίτσος Παρασκευάς
        // ── Additional faculty (no demo account) ──────────────────────────────────
        ["Επίκ. Αλεφραγκής"]   = "",
        ["Λεκτ. Αντωνόπουλος Γ."] = "",
        ["Επίκ. Αντωνόπουλος Χ."] = "",
        ["Λεκτ. Ασημακόπουλος"] = "",
        ["Καθ. Βώρος"]          = "",
        ["Επίκ. Γεωργάκας"]    = "",
        ["Καθ. Δροσόπουλος"]   = "",
        ["Καθ. Δρόσος"]        = "",
        ["Καθ. Ζαχαράκης"]     = "",
        ["Επίκ. Ζέρβας"]       = "",
        ["Επίκ. Καρέλης"]      = "",
        ["Καθ. Καψάλης"]       = "",
        ["Καθ. Κούγιας"]       = "",
        ["Αναπλ. Κούτρας"]     = "",
        ["Καθ. Μπισδούνης"]    = "",
        ["Αναπλ. Πετρέλλης"]   = "",
        ["Επίκ. Πολίτη"]       = "",
        ["Επίκ. Σουλιώτης"]    = "",
        ["Καθ. Σταθάτος"]      = "",
        ["Καθ. Συρμακέσης"]    = "",
        ["Επίκ. Σχοινάς"]      = "",
        ["Επίκ. Σωτηρόπουλος"] = "",
        ["Αναπλ. Τζήμας"]      = "",
        ["Καθ. Τριανταφύλλου"] = "",
        ["Αναπλ. Τσακνάκης"]   = "",
        ["Καθ. Χαδέλης"]       = "",
        ["Επίκ. Χαραλαμπάκος"] = "",
        ["Επίκ. Χριστοδούλου"] = "",
        ["Ομότ. Υφαντής"]      = "",
    };

    // Professors loaded from the database (display name + email pairs for the dropdown)
    private List<(string DisplayName, string Email)> _professorOptions = new();

    private sealed class ThesisTopic
    {
        public Guid Id { get; init; } = Guid.NewGuid();
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Status { get; set; } = TopicStatus.Draft;
        public string Area { get; set; } = string.Empty;
        public string SupervisingProfessor { get; set; } = string.Empty;
        public string SupervisingProfessorAccount { get; set; } = string.Empty;
        public string Prerequisites { get; set; } = string.Empty;
        public int MaxStudents { get; set; } = 1;
        public string ProposedBy { get; set; } = string.Empty;
        public DateTime ProposedOn { get; set; } = DateTime.UtcNow;
        public string? AssignedStudentAccount { get; set; }
        public List<TopicInterestDto> InterestedStudents { get; } = new();
    }

    private sealed record TopicInterestDto(string StudentEmail, string ProfessorEmail, DateTime ExpressedOn);

    private sealed class TopicFormModel
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Area { get; set; } = string.Empty;
        public string SupervisingProfessor { get; set; } = string.Empty;
        public string Prerequisites { get; set; } = string.Empty;
        public int MaxStudents { get; set; } = 1;

        public void Clear()
        {
            Title = Description = Area = SupervisingProfessor = Prerequisites = string.Empty;
            MaxStudents = 1;
        }

        public void Load(ThesisTopic t)
        {
            Title = t.Title;
            Description = t.Description;
            Area = t.Area;
            SupervisingProfessor = t.SupervisingProfessor;
            Prerequisites = t.Prerequisites;
            MaxStudents = t.MaxStudents;
        }
    }

    private readonly List<ThesisTopic> _topics = new();
    private readonly TopicFormModel _form = new();
    private readonly Dictionary<string, string> _formErrors = new();
    private readonly HashSet<Guid> _topicActionInProgressIds = new();
    private readonly Dictionary<Guid, string> _directAssignEmails = new();

    private bool _showForm;
    private Guid? _editingId;
    private string _searchText = string.Empty;
    private string _filterStatus = string.Empty;
    private string _filterArea = string.Empty;
    private string _sortOrder = "Newest";
    private string? _successMessage;
    private string? _errorMessage;

    private string CurrentAccount => NormalizeAccount(Session.UserName);

    protected override async Task OnInitializedAsync()
    {
        SeedSampleTopics();
        await ApplyPersistedStateAsync();
        await LoadProfessorOptionsAsync();
    }

    private async Task LoadProfessorOptionsAsync()
    {
        var emails = await TopicAssignmentService.GetAllProfessorEmailsAsync();
        var emailToName = _professorNameToAccount
            .Where(kvp => !string.IsNullOrEmpty(kvp.Value))
            .GroupBy(kvp => kvp.Value, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.First().Key, StringComparer.OrdinalIgnoreCase);
        _professorOptions = emails
            .Select(e => (
                DisplayName: emailToName.TryGetValue(e, out var name) ? name : e,
                Email: e))
            .OrderBy(o => o.DisplayName)
            .ToList();
    }

    private void SeedSampleTopics()
    {
        if (_topics.Count > 0)
        {
            return;
        }

        _topics.Add(new ThesisTopic
        {
            Id = TopicIdFederatedLearning,
            Title = "Σχεδίαση Συστήματος Βιομηχανικής Αυτοματοποίησης με Αλγορίθμους Μηχανικής Μάθησης",
            Description = "Μελέτη και υλοποίηση συστήματος ευφυούς βιομηχανικής αυτοματοποίησης που χρησιμοποιεί τεχνικές μηχανικής μάθησης για βελτιστοποίηση παραγωγικών διαδικασιών και προγνωστική συντήρηση εξοπλισμού.",
            Status = TopicStatus.Draft,
            Area = "Ηλεκτρονικής, Υπολογιστών και Συστημάτων",
            SupervisingProfessor = "Καθ. Βλαχόπουλος",
            SupervisingProfessorAccount = "prof1@univ.edu",
            Prerequisites = "Ψηφιακά Συστήματα, Python, Βασικές αρχές ML",
            MaxStudents = 1,
            ProposedBy = "Καθ. Βλαχόπουλος",
            ProposedOn = DateTime.UtcNow.AddDays(-3),
        });

        _topics.Add(new ThesisTopic
        {
            Id = TopicIdNetworkSlicing,
            Title = "5G Network Slicing για Βιομηχανικές Εφαρμογές IoT",
            Description = "Σχεδιασμός και αξιολόγηση πλαισίου network slicing προσαρμοσμένου σε βιομηχανικές εφαρμογές IoT με αυστηρές απαιτήσεις καθυστέρησης, χρησιμοποιώντας τεχνικές επεξεργασίας σήματος και διαχείρισης δικτύων 5G.",
            Status = TopicStatus.Open,
            Area = "Σημάτων, Τηλεπικοινωνιών και Δικτύων",
            SupervisingProfessor = "Αναπλ. Παρασκευάς",
