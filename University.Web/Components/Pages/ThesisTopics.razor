    private async Task ApplyPersistedStateAsync()
    {
        var persistedAssignments = await TopicAssignmentService.GetPersistedAssignmentsAsync();
        var persistedInterests = await InterestService.GetInterestsAsync();

        foreach (var topic in _topics)
        {
            topic.InterestedStudents.Clear();

            foreach (var interest in persistedInterests.Where(i => i.TopicId == topic.Id))
            {
                topic.InterestedStudents.Add(new TopicInterestDto(
                    NormalizeAccount(interest.StudentEmail),
                    NormalizeAccount(interest.ProfessorEmail),
                    interest.ExpressedOn));
            }

            if (!persistedAssignments.TryGetValue(topic.Id, out var assignment))
            {
                continue;
            }

            topic.Status = TopicStatus.Ongoing;
            topic.AssignedStudentAccount = NormalizeAccount(assignment.StudentEmail);
            topic.SupervisingProfessorAccount = NormalizeAccount(assignment.ProfessorEmail);
        }
    }

    private IEnumerable<ThesisTopic> FilteredTopics
    {
        get
        {
            IEnumerable<ThesisTopic> q = _topics.Where(IsVisibleToCurrentUser);

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var term = _searchText.Trim();
                q = q.Where(t =>
                    t.Title.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    t.Description.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    t.ProposedBy.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    t.SupervisingProfessor.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            if (!string.IsNullOrWhiteSpace(_filterStatus))
            {
                q = q.Where(t => t.Status == _filterStatus);
            }

            if (!string.IsNullOrWhiteSpace(_filterArea))
            {
                q = q.Where(t => t.Area == _filterArea);
            }

            q = _sortOrder switch
            {
                "Oldest" => q.OrderBy(t => t.ProposedOn),
                "Title" => q.OrderBy(t => t.Title),
                "Status" => q.OrderBy(t => t.Status),
                _ => q.OrderByDescending(t => t.ProposedOn),
            };

            return q;
        }
    }

    private bool IsVisibleToCurrentUser(ThesisTopic topic)
    {
        if (Session.Role == UserRole.Student)
        {
            return IsPublicStatus(topic.Status) ||
                   (topic.Status == TopicStatus.Ongoing && IsCurrentStudentAssigned(topic));
        }

        return IsPublicStatus(topic.Status) ||
               ((topic.Status == TopicStatus.Ongoing || topic.Status == TopicStatus.Draft) && IsCurrentProfessorInCharge(topic));
    }

    private static bool IsPublicStatus(string status) =>
        status == TopicStatus.Open || status == TopicStatus.Archived;

    private bool IsCurrentProfessorInCharge(ThesisTopic topic)
    {
        if (Session.Role != UserRole.Professor)
        {
            return false;
        }

        var account = CurrentAccount;
        if (string.IsNullOrWhiteSpace(account))
        {
            return false;
        }

        return NormalizeAccount(topic.SupervisingProfessorAccount) == account;
    }

    private bool IsCurrentStudentAssigned(ThesisTopic topic)
    {
        if (Session.Role != UserRole.Student)
        {
            return false;
        }

        return NormalizeAccount(topic.AssignedStudentAccount) == CurrentAccount;
    }

    private void OpenProposalForm()
    {
        _form.Clear();
        _editingId = null;
        _formErrors.Clear();
        _showForm = true;

        if (Session.Role == UserRole.Professor)
        {
            var account = CurrentAccount;
            var opt = _professorOptions.FirstOrDefault(o =>
                string.Equals(o.Email, account, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(opt.Email))
                _form.SupervisingProfessor = opt.DisplayName;
        }
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingId = null;
        _formErrors.Clear();
    }

    private void EditTopic(ThesisTopic topic)
    {
        if (Session.Role == UserRole.Professor && !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        _form.Load(topic);
        _editingId = topic.Id;
        _formErrors.Clear();
        _showForm = true;
        _successMessage = null;
        _errorMessage = null;
    }

    private bool ValidateForm()
    {
        _formErrors.Clear();

        if (string.IsNullOrWhiteSpace(_form.Title))
        {
            _formErrors["Title"] = "Title is required.";
        }
        else if (_form.Title.Trim().Length < 10)
        {
            _formErrors["Title"] = "Title must be at least 10 characters.";
        }

        if (string.IsNullOrWhiteSpace(_form.Description))
        {
            _formErrors["Description"] = "Description is required.";
        }
        else if (_form.Description.Trim().Length < 30)
        {
            _formErrors["Description"] = "Description must be at least 30 characters.";
        }

        if (string.IsNullOrWhiteSpace(_form.SupervisingProfessor))
        {
            _formErrors["SupervisingProfessor"] = "Supervising professor is required.";
        }

        return _formErrors.Count == 0;
    }

    private void SubmitForm()
    {
        SaveTopic(TopicStatus.Draft);
    }

    private void SaveAndOpen()
    {
        SaveTopic(TopicStatus.Open);
    }

    private void SaveTopic(string newStatus)
    {
        if (!ValidateForm())
        {
            return;
        }

        if (_editingId.HasValue)
        {
            var topic = _topics.FirstOrDefault(t => t.Id == _editingId.Value);
            if (topic is not null)
            {
                topic.Title = _form.Title.Trim();
                topic.Description = _form.Description.Trim();
                topic.Area = _form.Area;
                topic.SupervisingProfessor = _form.SupervisingProfessor.Trim();
                topic.SupervisingProfessorAccount = ResolveProfessorAccount(topic.SupervisingProfessor, topic.SupervisingProfessorAccount);
                topic.Prerequisites = _form.Prerequisites.Trim();
                topic.MaxStudents = _form.MaxStudents;
                topic.Status = newStatus;
            }
            _successMessage = "Topic updated successfully.";
        }
        else
        {
            var supervisingProfessor = _form.SupervisingProfessor.Trim();
            var supervisingAccount = ResolveProfessorAccount(supervisingProfessor, Session.Role == UserRole.Professor ? CurrentAccount : string.Empty);
            _topics.Insert(0, new ThesisTopic
            {
                Id = Guid.NewGuid(),
                Title = _form.Title.Trim(),
                Description = _form.Description.Trim(),
                Status = newStatus,
                Area = _form.Area,
                SupervisingProfessor = supervisingProfessor,
                SupervisingProfessorAccount = supervisingAccount,
                Prerequisites = _form.Prerequisites.Trim(),
                MaxStudents = _form.MaxStudents,
                ProposedBy = Session.UserName ?? (Session.Role == UserRole.Student ? "Student" : "Professor"),
                ProposedOn = DateTime.UtcNow,
            });

            _successMessage = newStatus == TopicStatus.Open
                ? "Topic published as Open."
                : "Topic saved as Draft.";
        }

        _errorMessage = null;
        _showForm = false;
        _editingId = null;
    }

    private void PublishTopic(Guid id)
    {
        var topic = _topics.FirstOrDefault(x => x.Id == id);
        if (topic is null || !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        topic.Status = TopicStatus.Open;
        _successMessage = $"'{topic.Title}' is now Open.";
        _errorMessage = null;
    }

    private void ArchiveTopic(Guid id)
    {
        var topic = _topics.FirstOrDefault(x => x.Id == id);
        if (topic is null || !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        topic.Status = TopicStatus.Archived;
        _successMessage = $"'{topic.Title}' archived.";
        _errorMessage = null;
    }

    private void DeleteDraft(Guid id)
    {
        var topic = _topics.FirstOrDefault(x => x.Id == id);
        if (topic is null || topic.Status != TopicStatus.Draft || !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        _topics.Remove(topic);
        _successMessage = $"Draft '{topic.Title}' deleted.";
        _errorMessage = null;
    }

    private async Task DeleteOpenTopicAsync(Guid id)
    {
        var topic = _topics.FirstOrDefault(x => x.Id == id);
        if (topic is null || topic.Status != TopicStatus.Open || !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        _topicActionInProgressIds.Add(id);
        try
        {
            await InterestService.ClearTopicInterestsAsync(topic.Id);
            _topics.Remove(topic);
            _successMessage = $"Topic '{topic.Title}' deleted.";
            _errorMessage = null;
        }
        finally
        {
            _topicActionInProgressIds.Remove(id);
        }
    }

    private bool HasCurrentStudentExpressedInterest(ThesisTopic topic)
    {
        if (Session.Role != UserRole.Student)
        {
            return false;
        }

        return topic.InterestedStudents.Any(interest => NormalizeAccount(interest.StudentEmail) == CurrentAccount);
    }

    private async Task ExpressInterestAsync(Guid id)
    {
        if (Session.Role != UserRole.Student)
        {
            return;
        }

        var topic = _topics.FirstOrDefault(x => x.Id == id);
        if (topic is null || topic.Status != TopicStatus.Open)
        {
            return;
        }

        if (HasCurrentStudentExpressedInterest(topic))
        {
            _successMessage = $"Your interest in '{topic.Title}' is already registered.";
            _errorMessage = null;
            return;
        }

        _topicActionInProgressIds.Add(id);
        try
        {
            var recorded = await InterestService.RecordInterestAsync(
                topic.Id,
                topic.Title,
                Session.UserName ?? string.Empty,
                topic.SupervisingProfessorAccount);

            if (!recorded)
            {
                _errorMessage = "Unable to register your interest.";
                _successMessage = null;
                return;
            }

            await ApplyPersistedStateAsync();

            _successMessage = $"Your interest in '{topic.Title}' has been sent to {topic.SupervisingProfessor}.";
            _errorMessage = null;
        }
        finally
        {
            _topicActionInProgressIds.Remove(id);
        }
    }

    private async Task AssignInterestedStudentAsync(Guid topicId, string studentEmail)
    {
        if (Session.Role != UserRole.Professor)
        {
            return;
        }

        var topic = _topics.FirstOrDefault(x => x.Id == topicId);
        if (topic is null || topic.Status != TopicStatus.Open || !IsCurrentProfessorInCharge(topic))
        {
            return;
        }

        var normalizedStudentEmail = NormalizeAccount(studentEmail);
        if (!topic.InterestedStudents.Any(interest => NormalizeAccount(interest.StudentEmail) == normalizedStudentEmail))
        {
            _errorMessage = "Choose a student who has expressed interest in this topic.";
            _successMessage = null;
            return;
        }

        _topicActionInProgressIds.Add(topicId);
        try
        {
            var result = await TopicAssignmentService.AssignTopicAsync(
                topic.Id,
                topic.Title,
                studentEmail,
                topic.SupervisingProfessorAccount);

            if (!result.Success)
            {
                _errorMessage = result.Error ?? "Unable to assign the selected student.";
                _successMessage = null;
                return;
            }

            await InterestService.RemoveInterestAsync(topicId, studentEmail);
            await ApplyPersistedStateAsync();

            topic.Status = TopicStatus.Ongoing;
            topic.AssignedStudentAccount = normalizedStudentEmail;
            _successMessage = $"'{topic.Title}' assigned to {normalizedStudentEmail}.";
            _errorMessage = null;
        }
        finally
        {
            _topicActionInProgressIds.Remove(topicId);
        }
    }

    private string ResolveProfessorAccount(string professorName, string fallback)
    {
        if (_professorNameToAccount.TryGetValue(professorName, out var mapped))
        {
            return mapped;
        }

        return string.IsNullOrWhiteSpace(fallback) ? string.Empty : fallback;
    }

    private void ClearFilters()
    {
        _searchText = string.Empty;
        _filterStatus = string.Empty;
        _filterArea = string.Empty;
        _sortOrder = "Newest";
    }

    private static string NormalizeAccount(string? value) => (value ?? string.Empty).Trim().ToLowerInvariant();

    private async Task DirectAssignStudentAsync(Guid topicId)
    {
        if (Session.Role != UserRole.Professor) return;

        var topic = _topics.FirstOrDefault(x => x.Id == topicId);
        if (topic is null || !IsCurrentProfessorInCharge(topic)) return;

        if (!_directAssignEmails.TryGetValue(topicId, out var studentEmail) || string.IsNullOrWhiteSpace(studentEmail))
        {
            _errorMessage = "Please enter a student email address.";
            _successMessage = null;
            return;
        }

        _topicActionInProgressIds.Add(topicId);
        try
        {
            var result = await TopicAssignmentService.AssignTopicAsync(
                topic.Id,
                topic.Title,
                studentEmail.Trim(),
                topic.SupervisingProfessorAccount);

            if (!result.Success)
            {
                _errorMessage = result.Error ?? "Unable to assign the student.";
                _successMessage = null;
                return;
            }

            await InterestService.RemoveInterestAsync(topicId, studentEmail.Trim());
            await ApplyPersistedStateAsync();

            topic.Status = TopicStatus.Ongoing;
            topic.AssignedStudentAccount = NormalizeAccount(studentEmail);
            _directAssignEmails.Remove(topicId);
            _successMessage = $"'{topic.Title}' assigned to {NormalizeAccount(studentEmail)}.";
            _errorMessage = null;
        }
        finally
        {
            _topicActionInProgressIds.Remove(topicId);
        }
    }

    private async Task RemoveAssignedStudentAsync(Guid topicId)
    {
        if (Session.Role != UserRole.Professor) return;

        var topic = _topics.FirstOrDefault(x => x.Id == topicId);
        if (topic is null || !IsCurrentProfessorInCharge(topic)) return;

        _topicActionInProgressIds.Add(topicId);
        try
        {
            var result = await TopicAssignmentService.RemoveAssignmentAsync(topic.Id);

            if (!result.Success)
            {
                _errorMessage = result.Error ?? "Unable to remove the assignment.";
                _successMessage = null;
                return;
            }

            topic.Status = TopicStatus.Open;
            topic.AssignedStudentAccount = null;
            _successMessage = $"Assignment removed. '{topic.Title}' is now Open.";
            _errorMessage = null;
        }
        finally
        {
            _topicActionInProgressIds.Remove(topicId);
        }
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        TopicStatus.Open => "badge bg-success",
        TopicStatus.Ongoing => "badge bg-primary",
        TopicStatus.Archived => "badge bg-secondary",
        TopicStatus.Draft => "badge bg-light text-dark border",
        _ => "badge bg-secondary",
    };
