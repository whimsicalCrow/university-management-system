@page "/dashboard"
@inject IStudentDashboardService DashboardService
@inject UserSessionService Session

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2"><span class="bi bi-kanban"></span> Dashboard</span>
            <h1 class="section-heading mb-2">Student Thesis Dashboard</h1>
            <p class="text-muted mb-0">Παρακολουθήστε τις βασικές ενότητες για πρόοδο, feedback και action items.</p>
        </div>
        <NavLink class="btn btn-primary mt-3 mt-lg-0" href="updates">Νέα ενημέρωση</NavLink>
    </div>

    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">Current Thesis</h2>
        @if (isLoading)
        {
            <div class="card info-card">
                <div class="card-body text-muted">Loading dashboard...</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(loadError))
        {
            <div class="alert alert-warning" role="alert">@loadError</div>
        }
        else if (dashboard.ActiveTheses.Count == 0)
        {
            <div class="card info-card">
                <div class="card-body">
                    <p class="text-muted mb-0">No active thesis assignments were found for your account.</p>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var thesis in dashboard.ActiveTheses)
                {
                    <div class="col-12 col-xl-6">
                        <div class="card info-card h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                                    <h3 class="h5 mb-0">@thesis.TopicTitle</h3>
                                    <span class="badge rounded-pill text-bg-primary">@thesis.Status</span>
                                </div>
                                <p class="small text-muted mb-2">Supervisor: @(thesis.SupervisorName ?? "Unassigned")</p>
                                <p class="mb-0">
                                    <span class="fw-semibold">Next milestone due:</span>
                                    @thesis.NextMilestoneDueOn.ToString("dd MMM yyyy")
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="mb-5">
        <h2 class="h4 fw-semibold mb-3">Latest Updates</h2>
        @if (dashboard.RecentComments.Count == 0)
        {
            <div class="card info-card">
                <div class="card-body">
                    <p class="text-muted mb-0">No supervisor comments yet. Submit an update to receive feedback.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card info-card">
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        @foreach (var comment in dashboard.RecentComments)
                        {
                            <li class="list-group-item px-0">
                                <div class="d-flex justify-content-between flex-wrap gap-2">
                                    <strong>@comment.Author</strong>
                                    <span class="small text-muted">@comment.CreatedOn.ToString("dd MMM yyyy")</span>
                                </div>
                                <p class="mb-1">@comment.Message</p>
                                <NavLink class="small" href="@($"updates?authorId={dashboard.StudentId}")">Open timeline</NavLink>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </section>

    <section>
        <h2 class="h4 fw-semibold mb-3">Action Items</h2>
        <div class="card info-card">
            <div class="card-body">
                @if (dashboard.ActionItems.Count == 0)
                {
                    <p class="text-muted mb-0">Outstanding tasks and deadlines will surface here for quick follow-up.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var action in dashboard.ActionItems)
                        {
                            <li class="list-group-item px-0">
                                <div class="d-flex justify-content-between flex-wrap gap-2">
                                    <strong>@action.Title</strong>
                                    @if (action.DueOn.HasValue)
                                    {
                                        <span class="small text-muted">Due @action.DueOn.Value.ToString("dd MMM")</span>
                                    }
                                </div>
                                <p class="mb-1">@action.Description</p>
                                <NavLink class="small" href="@action.Href">Go to task</NavLink>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </section>

    <section class="mt-4">
        <h2 class="h4 fw-semibold mb-3">Thesis Shortcuts</h2>
        <div class="d-flex flex-wrap gap-2">
            <NavLink class="btn btn-outline-primary btn-sm" href="@TimelineLink">Update timeline</NavLink>
            <NavLink class="btn btn-outline-primary btn-sm" href="@FileLibraryLink">File library</NavLink>
            <NavLink class="btn btn-outline-primary btn-sm" href="@MeetingsLink">Meeting scheduler</NavLink>
        </div>
    </section>

    <section class="mt-5">
        <h2 class="h4 fw-semibold mb-3">How to Use the Platform</h2>
        <div class="card info-card">
            <div class="card-body">
                <p class="text-muted mb-3">Follow this short flow to keep your thesis work organized:</p>
                <ol class="mb-3">
                    <li><strong>Start from Thesis Topics:</strong> Browse available topics, express interest, or submit your own topic suggestion.</li>
                    <li><strong>Write Updates:</strong> Go to Thesis Updates and post your weekly progress for supervisor review.</li>
                    <li><strong>Book a Meeting:</strong> Open Meetings, choose your professor, and reserve an open slot.</li>
                    <li><strong>Track Follow-ups:</strong> Return here to monitor pending tasks and upcoming deadlines.</li>
                </ol>
                <div class="d-flex flex-wrap gap-2">
                    <NavLink class="btn btn-outline-primary btn-sm" href="thesis-topics">1. Thesis Topics</NavLink>
                    <NavLink class="btn btn-outline-primary btn-sm" href="updates">2. Thesis Updates</NavLink>
                    <NavLink class="btn btn-outline-primary btn-sm" href="meetings">3. Meetings</NavLink>
                </div>
            </div>
        </div>
    </section>
</div>

@code {
    private StudentDashboardData dashboard = StudentDashboardData.Empty;
    private bool isLoading = true;
    private string? loadError;

    private string TimelineLink
        => dashboard.ActiveTheses.Count == 0 || dashboard.StudentId is null
            ? "updates"
            : $"updates?thesisId={dashboard.ActiveTheses[0].TopicId}&authorId={dashboard.StudentId.Value}";

    private string FileLibraryLink
        => dashboard.ActiveTheses.Count == 0 || dashboard.StudentId is null
            ? "file-library"
            : $"file-library?thesisId={dashboard.ActiveTheses[0].TopicId}&authorId={dashboard.StudentId.Value}";

    private string MeetingsLink
        => dashboard.ActiveTheses.Count == 0 || dashboard.StudentId is null
            ? "meetings"
            : $"meetings?thesisId={dashboard.ActiveTheses[0].TopicId}&authorId={dashboard.StudentId.Value}";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.Role != UserRole.Student)
        {
            isLoading = false;
            loadError = "Please sign in as a student to view your dashboard.";
            return;
        }

        dashboard = await DashboardService.GetDashboardAsync(Session.UserName);
        isLoading = false;
    }
}
