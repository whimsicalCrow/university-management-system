@page "/updates"
@using System.Globalization
@using System.Linq
@using System.Net
@using System.Text.RegularExpressions
@using System.Threading
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Markdig

@implements IDisposable
@inject IJSRuntime JS
@inject UserSessionService Session
@inject IThesisArtifactStorageService ArtifactStorage

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2">
                <span class="bi bi-journal-text"></span>
                Thesis Progress
            </span>
            <h1 class="section-heading mb-2">Χρονογραμμή Ενημερώσεων</h1>
            <p class="text-muted mb-0">
                Καταγράψτε δομημένες ενημερώσεις και παρακολουθήστε την ιστορικότητα της διπλωματικής εργασίας.
            </p>
        </div>
        @if (!IsSupervisorView)
        {
            <button class="btn btn-outline-primary mt-3 mt-lg-0" @onclick="LoadTimelineAsync" disabled="@MissingContext">
                <span class="bi bi-arrow-repeat"></span>
                Ανανέωση
            </button>
        }
    </div>

    @if (MissingContext)
    {
        <div class="alert alert-warning" role="alert">
            <span class="bi bi-info-circle me-2"></span>
            Προσθέστε τα παραμέτρους <code>thesisId</code> και <code>authorId</code> στο URL για να ενεργοποιηθεί η ροή ενημερώσεων.
        </div>
    }
    else
    {
        @if (!IsSupervisorView)
        {
            <section class="card compose-card mb-5">
                <div class="card-body">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-4">
                        <div class="flex-fill">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="w-100 me-3">
                                    <label for="new-update-title" class="form-label fw-semibold mb-1">Νέα ενημέρωση</label>
                                    <input id="new-update-title"
                                           class="form-control"
                                           placeholder="Πληκτρολογήστε τίτλο ενημέρωσης..."
                                           value="@updateTitle"
                                           @oninput="OnTitleInput"
                                           disabled="@isSaving" />
                                </div>
                                <span class="badge draft-badge">Αποθήκευση πρόχειρου κάθε 2,5''</span>
                            </div>
                            <div class="editor-toolbar d-flex flex-wrap gap-2 mb-3">
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Heading" @onclick="() => ApplyFormattingAsync(EditorFormat.Heading)" disabled="@isSaving">H2</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Bold" @onclick="() => ApplyFormattingAsync(EditorFormat.Bold)" disabled="@isSaving"><span class="fw-bold">B</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Italic" @onclick="() => ApplyFormattingAsync(EditorFormat.Italic)" disabled="@isSaving"><span class="fst-italic">I</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Bulleted list" @onclick="() => ApplyFormattingAsync(EditorFormat.UnorderedList)" disabled="@isSaving"><span class="bi bi-list-ul me-1" aria-hidden="true"></span><span>UL</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Numbered list" @onclick="() => ApplyFormattingAsync(EditorFormat.OrderedList)" disabled="@isSaving"><span class="bi bi-list-ol me-1" aria-hidden="true"></span><span>OL</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Quote" @onclick="() => ApplyFormattingAsync(EditorFormat.Quote)" disabled="@isSaving"><span class="bi bi-blockquote-left me-1" aria-hidden="true"></span><span>Quote</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Code block" @onclick="() => ApplyFormattingAsync(EditorFormat.Code)" disabled="@isSaving"><span class="bi bi-code-slash me-1" aria-hidden="true"></span><span>Code</span></button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" title="Link" @onclick="() => ApplyFormattingAsync(EditorFormat.Link)" disabled="@isSaving"><span class="bi bi-link-45deg me-1" aria-hidden="true"></span><span>Link</span></button>
                            </div>
                            <textarea class="form-control update-editor"
                                      placeholder="Περιγράψτε την πρόοδό σας χρησιμοποιώντας Markdown..."
                                      rows="10"
                                      value="@editorContent"
                                      @ref="editorRef"
                                      @oninput="OnEditorInput"
                                      disabled="@isSaving"></textarea>

                            <div class="attachment-panel mt-3">
                                <label class="form-label fw-semibold mb-2">Attachment (ZIP)</label>
                                <InputFile OnChange="OnAttachmentSelected"
                                           accept=".zip,application/zip"
                                           disabled="@isSaving"
                                           class="form-control" />
                                @if (!string.IsNullOrWhiteSpace(selectedAttachmentName))
                                {
                                    <div class="small text-muted mt-2">
                                        <span class="bi bi-paperclip me-1"></span>
                                        @selectedAttachmentName (@FormatFileSize(selectedAttachmentSizeBytes ?? 0))
                                    </div>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(validationMessage))
                            {
                                <div class="alert alert-danger mt-3" role="alert">
                                    <span class="bi bi-exclamation-triangle-fill me-2"></span>
                                    @validationMessage
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(autosaveMessage))
                            {
                                <div class="alert alert-secondary autosave-banner mt-3" role="status">
                                    <span class="bi bi-cloud-check me-2"></span>
                                    @autosaveMessage
                                </div>
                            }

                            <div class="d-flex flex-column flex-md-row gap-3 mt-4">
                                <button class="btn btn-outline-primary" @onclick="SaveDraftAsync" disabled="@isSaving">
                                    <span class="bi bi-cloud-arrow-down"></span>
                                    Αποθήκευση πρόχειρου
                                </button>
                                <button class="btn btn-primary" @onclick="PublishAsync" disabled="@isSaving">
                                    @if (isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <span class="bi bi-send"></span>
                                    Αποστολή για αξιολόγηση
                                </button>
                            </div>
                        </div>

                        <div class="preview-pane flex-fill">
                            <div class="preview-header">
                                <span class="bi bi-eye"></span>
                                Προεπισκόπηση Markdown
                            </div>
                            <div class="preview-content" @onclick:stopPropagation="true">
                                @if (string.IsNullOrWhiteSpace(editorContent))
                                {
                                    <p class="text-muted mb-0">Η προεπισκόπηση εμφανίζεται καθώς πληκτρολογείτε.</p>
                                }
                                else
                                {
                                    @PreviewMarkup
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        }

        <section class="timeline-controls mb-4">
            <div class="card info-card">
                <div class="card-body d-flex flex-column flex-lg-row gap-3 align-items-lg-center justify-content-between">
                    <div>
                        <h2 class="h6 text-uppercase text-muted mb-1">Φίλτρα προβολής</h2>
                        <p class="mb-0 text-muted">Επιλέξτε κατάσταση για να επικεντρωθείτε στις ενημερώσεις που σας ενδιαφέρουν.</p>
                    </div>
                    <div class="d-flex flex-column flex-md-row align-items-stretch gap-3">
                        <select class="form-select timeline-filter" value="@statusFilter" @onchange="OnFilterChanged">
                            <option value="">Όλες οι καταστάσεις</option>
                            @foreach (var status in FilterableStatuses)
                            {
                                <option value="@status" selected="@status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase)">@status</option>
                            }
                        </select>
                        @if (IsSupervisorView)
                        {
                            <span class="badge bg-info-subtle text-info-emphasis">
                                <span class="bi bi-git me-1"></span>
                                Λειτουργία αξιολόγησης επιβλέποντα
                            </span>
                        }
                    </div>
                </div>
            </div>
        </section>

        <section class="timeline-section">
            @if (timeline.Count == 0)
            {
                <div class="card info-card">
                    <div class="card-body text-center text-muted py-5">
                        <span class="bi bi-clipboard2-data mb-3 timeline-empty-icon"></span>
                        <p class="mb-0">Δεν υπάρχουν ακόμη ενημερώσεις για εμφάνιση.</p>
                    </div>
                </div>
            }
            else
            {
                <ul class="timeline list-unstyled">
                    @foreach (var item in timeline)
                    {
                        <li class="timeline-entry">
                            <div class="timeline-marker"></div>
                            <div class="timeline-card card">
                                <div class="card-body">
                                    <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <span class="@StatusBadgeClass(item.Status)">@item.Status</span>
                                            <span class="timeline-date">@FormatDate(item.OccurredOn)</span>
                                            @if (WasEdited(item))
                                            {
                                                <span class="edited-indicator">
                                                    <span class="bi bi-pencil-square"></span>
                                                    Ενημερώθηκε @FormatDate(item.LastModifiedOn)
                                                </span>
                                            }
                                        </div>
                                        <span class="timeline-author text-muted small">
                                            <span class="bi bi-person-circle me-1"></span>
                                            Φοιτητής
                                        </span>
                                    </div>

                                    <h3 class="h6 fw-semibold mb-2">@item.Title</h3>
                                    <p class="timeline-snippet mb-1">@BuildSnippet(item.Note)</p>
                                    @if (!string.IsNullOrWhiteSpace(item.AttachmentFileName))
                                    {
                                        <div class="small text-muted mb-2">
                                            <span class="bi bi-file-earmark-zip me-1"></span>
                                            @if (item.ArtifactId.HasValue)
                                            {
                                                <a href="@($"/api/thesis-artifacts/{item.ArtifactId.Value}")" download="@item.AttachmentFileName">@item.AttachmentFileName</a>
                                            }
                                            else
                                            {
                                                @item.AttachmentFileName
                                            }
                                            @if (item.AttachmentSizeBytes.HasValue)
                                            {
                                                <span>(@FormatFileSize(item.AttachmentSizeBytes.Value))</span>
                                            }
                                        </div>
                                    }

                                    @if (item.ProfessorComments.Count > 0)
                                    {
                                        <div class="mt-3 p-3 border rounded bg-light-subtle">
                                            <div class="small text-uppercase text-muted fw-semibold mb-2">Professor comments</div>
                                            @foreach (var comment in item.ProfessorComments.OrderByDescending(c => c.CreatedOn))
                                            {
                                                <div class="mb-2">
                                                    <div class="small fw-semibold">@comment.Author · @FormatDate(comment.CreatedOn)</div>
                                                    <div class="small">@comment.Message</div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    @if (IsSupervisorView)
                                    {
                                        <details class="mt-3 p-3 border rounded">
                                            <summary class="small text-uppercase text-muted fw-semibold mb-2">Review update</summary>
                                            <div class="d-flex flex-column gap-2 mt-2">
                                                <select class="form-select form-select-sm"
                                                        value="@GetProfessorStatusSelection(item.Id, item.Status)"
                                                        @onchange="args => OnProfessorStatusChanged(item.Id, args)">
                                                    @foreach (var reviewStatus in ReviewableStatuses)
                                                    {
                                                        <option value="@reviewStatus">@reviewStatus</option>
                                                    }
                                                </select>
                                                <textarea class="form-control"
                                                          rows="3"
                                                          placeholder="Προσθέστε σχόλιο αξιολόγησης..."
                                                          value="@GetProfessorCommentDraft(item.Id)"
                                                          @oninput="args => OnProfessorCommentInput(item.Id, args)"></textarea>
                                                <button type="button" class="btn btn-sm btn-primary align-self-start" @onclick="() => ApplyProfessorReviewAsync(item.Id)">
                                                    <span class="bi bi-check2-circle me-1"></span>
                                                    Submit review
                                                </button>
                                            </div>
                                        </details>
                                    }
                                    <button class="btn btn-link p-0 mt-2" type="button" data-bs-toggle="collapse" data-bs-target="#update-@item.Id" aria-expanded="false" aria-controls="update-@item.Id">
                                        <span class="bi bi-arrows-expand"></span>
                                        Προβολή πλήρους περιεχομένου
                                    </button>
                                    <div class="collapse mt-3" id="update-@item.Id">
                                        <div class="timeline-full"
                                             @onclick:stopPropagation="true"
                                             @key="item.Id">
                                            @((MarkupString)Markdown.ToHtml(item.Note, MarkdownPipeline))
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>
    }
</div>

@code {
    private const int AutosaveDelayMilliseconds = 2500;
    private const long MaxAttachmentSizeBytes = 25 * 1024 * 1024;
    private static readonly Guid PlaceholderThesisId = Guid.Parse("11111111-1111-1111-1111-111111111111");
    private static readonly Guid PlaceholderAuthorId = Guid.Parse("22222222-2222-2222-2222-222222222222");
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder().UseAdvancedExtensions().Build();

    private enum EditorFormat
    {
        Heading,
        Bold,
        Italic,
        UnorderedList,
        OrderedList,
        Quote,
        Code,
        Link,
    }

    // ── Local stub types ────────────────────────────────────────────────────
    private static class ThesisUpdateStatuses
    {
        public const string Draft       = "Draft";
        public const string UnderReview = "Under review";
        public const string Approved    = "Approved";
        public static IReadOnlyList<string> All { get; } = new[] { Draft, UnderReview, Approved };
        public static IReadOnlyList<string> Reviewable { get; } = new[] { UnderReview, Approved };
    }

    private sealed record ProfessorCommentDto(Guid Id, string Author, string Message, DateTime CreatedOn);

    private sealed record ThesisUpdateTimelineDto(
        Guid Id,
        Guid AuthorId,
        string Title,
        string Status,
        string Note,
        DateTime OccurredOn,
        DateTime LastModifiedOn,
        string? AttachmentFileName,
        long? AttachmentSizeBytes,
        Guid? ArtifactId,
        IReadOnlyList<ProfessorCommentDto> ProfessorComments);

    // ── State ────────────────────────────────────────────────────────────────
    private readonly List<ThesisUpdateTimelineDto> _store = new();
    private readonly List<ThesisUpdateTimelineDto> timeline = new();
    private static readonly IReadOnlyList<string> AvailableStatuses = ThesisUpdateStatuses.All.ToArray();

    private string editorContent = string.Empty;
    private string updateTitle = string.Empty;
    private string previewHtml = string.Empty;
    private string statusFilter = string.Empty;
    private string? validationMessage;
    private string? autosaveMessage;
    private Guid? draftUpdateId;
    private bool isSaving;
    private CancellationTokenSource? autosaveCts;
    private Guid loadedThesisId;
    private ElementReference editorRef;
    private string? selectedAttachmentName;
    private long? selectedAttachmentSizeBytes;
    private IBrowserFile? selectedAttachmentFile;
    private readonly Dictionary<Guid, string> professorCommentDrafts = new();
    private readonly Dictionary<Guid, string> professorStatusSelections = new();

    [SupplyParameterFromQuery(Name = "thesisId")]
    public Guid ThesisId { get; set; }

    [SupplyParameterFromQuery(Name = "authorId")]
    public Guid AuthorId { get; set; }

    [SupplyParameterFromQuery(Name = "role")]
    public string? Role { get; set; }

    private Guid ResolvedThesisId => ThesisId == Guid.Empty ? PlaceholderThesisId : ThesisId;

    private Guid ResolvedAuthorId => AuthorId == Guid.Empty ? PlaceholderAuthorId : AuthorId;

    private bool MissingContext => false;

    private bool IsSupervisorView =>
        Session.Role == UserRole.Professor ||
        string.Equals(Role, "supervisor", StringComparison.OrdinalIgnoreCase);

    private IEnumerable<string> FilterableStatuses => IsSupervisorView
        ? AvailableStatuses.Where(s => !s.Equals(ThesisUpdateStatuses.Draft, StringComparison.OrdinalIgnoreCase))
        : AvailableStatuses;

    private IEnumerable<string> ReviewableStatuses => ThesisUpdateStatuses.Reviewable;

    protected override async Task OnParametersSetAsync()
    {
        if (MissingContext)
        {
            timeline.Clear();
            return;
        }

        if (loadedThesisId != ResolvedThesisId)
        {
            loadedThesisId = ResolvedThesisId;
            SeedSampleData();
            await LoadTimelineAsync();
        }
    }

    private void SeedSampleData()
    {
        if (_store.Count > 0) return;

        var authorId = ResolvedAuthorId;
        var now = DateTime.UtcNow;

        _store.AddRange(new[]
        {
            new ThesisUpdateTimelineDto(Guid.NewGuid(), authorId, "Literature Review Complete", ThesisUpdateStatuses.Approved,
                "## Literature Review Complete\n\nCompleted the survey of 30+ papers. Key themes identified: distributed systems, consensus algorithms, and fault tolerance.",
                now.AddDays(-14), now.AddDays(-14), "literature-review-pack.zip", 2_934_100,
                null,
                new[]
                {
                    new ProfessorCommentDto(Guid.NewGuid(), "Prof. Papadopoulos", "Solid literature synthesis. Proceed to implementation milestones.", now.AddDays(-13))
                }),
            new ThesisUpdateTimelineDto(Guid.NewGuid(), authorId, "Methodology Draft", ThesisUpdateStatuses.UnderReview,
                "## Methodology Draft\n\nFirst draft of the methodology chapter. Professor requested more detail on the validation approach and experimental setup.",
                now.AddDays(-7), now.AddDays(-5), null, null, null,
                new[]
                {
                    new ProfessorCommentDto(Guid.NewGuid(), "Prof. Papadopoulos", "Please clarify evaluation criteria and include baseline comparison.", now.AddDays(-5))
                }),
            new ThesisUpdateTimelineDto(Guid.NewGuid(), authorId, "Implementation Progress", ThesisUpdateStatuses.UnderReview,
                "## Implementation Progress\n\nCore module implemented and all unit tests passing. Integration tests with the database layer still pending.",
                now.AddDays(-2), now.AddDays(-2), "sprint-3-deliverables.zip", 10_885_221,
                null,
                Array.Empty<ProfessorCommentDto>()),
        });
    }

    private Task LoadTimelineAsync()
    {
        IEnumerable<ThesisUpdateTimelineDto> filtered = _store;

        if (!string.IsNullOrWhiteSpace(statusFilter))
            filtered = filtered.Where(u => u.Status.Equals(statusFilter, StringComparison.OrdinalIgnoreCase));

        if (IsSupervisorView)
            filtered = filtered.Where(u => !u.Status.Equals(ThesisUpdateStatuses.Draft, StringComparison.OrdinalIgnoreCase));

        timeline.Clear();
        timeline.AddRange(filtered.OrderByDescending(u => u.OccurredOn));

        foreach (var update in timeline)
        {
            if (!professorStatusSelections.ContainsKey(update.Id))
            {
                professorStatusSelections[update.Id] = update.Status;
            }

            if (!professorCommentDrafts.ContainsKey(update.Id))
            {
                professorCommentDrafts[update.Id] = string.Empty;
            }
        }

        if (!IsSupervisorView && draftUpdateId is null && string.IsNullOrWhiteSpace(editorContent))
        {
            var draft = timeline.FirstOrDefault(u =>
                u.AuthorId == ResolvedAuthorId &&
                u.Status.Equals(ThesisUpdateStatuses.Draft, StringComparison.OrdinalIgnoreCase));

            if (draft is not null)
            {
                draftUpdateId = draft.Id;
                updateTitle = draft.Title;
                editorContent = draft.Note;
                previewHtml = Markdown.ToHtml(editorContent, MarkdownPipeline);
            }
        }

        return Task.CompletedTask;
    }

    private async Task OnFilterChanged(ChangeEventArgs args)
    {
        statusFilter = args.Value?.ToString() ?? string.Empty;
        await LoadTimelineAsync();
    }

    private void OnEditorInput(ChangeEventArgs args)
    {
        editorContent = args.Value?.ToString() ?? string.Empty;
        validationMessage = null;
        previewHtml = Markdown.ToHtml(editorContent, MarkdownPipeline);
        ScheduleAutosave();
    }

    private void OnTitleInput(ChangeEventArgs args)
    {
        updateTitle = args.Value?.ToString() ?? string.Empty;
        validationMessage = null;
        ScheduleAutosave();
    }

    private async Task ApplyFormattingAsync(EditorFormat format)
    {
        editorContent = await JS.InvokeAsync<string>("thesisUpdatesEditor.applyMarkdown", editorRef, format.ToString());
        validationMessage = null;
        previewHtml = Markdown.ToHtml(editorContent, MarkdownPipeline);
        ScheduleAutosave();
    }

    private void OnAttachmentSelected(InputFileChangeEventArgs args)
    {
        validationMessage = null;

        if (args.FileCount == 0)
        {
            selectedAttachmentName = null;
            selectedAttachmentSizeBytes = null;
            selectedAttachmentFile = null;
            return;
        }

        var file = args.File;

        if (!file.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            validationMessage = "Επιτρέπονται μόνο αρχεία ZIP για την υποβολή ενημέρωσης.";
            selectedAttachmentName = null;
            selectedAttachmentSizeBytes = null;
            selectedAttachmentFile = null;
            return;
        }

        if (file.Size > MaxAttachmentSizeBytes)
        {
            validationMessage = $"Το αρχείο ZIP υπερβαίνει το όριο των {FormatFileSize(MaxAttachmentSizeBytes)}.";
            selectedAttachmentName = null;
            selectedAttachmentSizeBytes = null;
            selectedAttachmentFile = null;
            return;
        }

        selectedAttachmentName = file.Name;
        selectedAttachmentSizeBytes = file.Size;
        selectedAttachmentFile = file;
    }

    private Task PublishAsync() => PersistAsync(ThesisUpdateStatuses.UnderReview, saveAsDraft: false, isAutosave: false);

    private Task SaveDraftAsync() => PersistAsync(ThesisUpdateStatuses.Draft, saveAsDraft: true, isAutosave: false);

    private void OnProfessorCommentInput(Guid updateId, ChangeEventArgs args)
    {
        professorCommentDrafts[updateId] = args.Value?.ToString() ?? string.Empty;
        validationMessage = null;
    }

    private string GetProfessorCommentDraft(Guid updateId) =>
        professorCommentDrafts.TryGetValue(updateId, out var value) ? value : string.Empty;

    private string GetProfessorStatusSelection(Guid updateId, string fallbackStatus) =>
        professorStatusSelections.TryGetValue(updateId, out var value) ? value : fallbackStatus;

    private void OnProfessorStatusChanged(Guid updateId, ChangeEventArgs args)
    {
        var selected = args.Value?.ToString() ?? ThesisUpdateStatuses.UnderReview;
        professorStatusSelections[updateId] = selected;
        validationMessage = null;
    }

    private async Task ApplyProfessorReviewAsync(Guid updateId)
    {
        var idx = _store.FindIndex(u => u.Id == updateId);
        if (idx < 0)
        {
            validationMessage = "Η ενημέρωση δεν βρέθηκε.";
            return;
        }

        var newStatus = professorStatusSelections.TryGetValue(updateId, out var status)
            ? status
            : ThesisUpdateStatuses.UnderReview;

        if (!ReviewableStatuses.Contains(newStatus, StringComparer.OrdinalIgnoreCase))
        {
            validationMessage = "Η κατάσταση αξιολόγησης δεν είναι έγκυρη.";
            return;
        }

        var reviewComment = professorCommentDrafts.TryGetValue(updateId, out var message)
            ? message.Trim()
            : string.Empty;

        var update = _store[idx];
        var comments = update.ProfessorComments.ToList();
        if (!string.IsNullOrWhiteSpace(reviewComment))
        {
            comments.Add(new ProfessorCommentDto(Guid.NewGuid(), "Professor", reviewComment, DateTime.UtcNow));
        }

        _store[idx] = update with
        {
            Status = newStatus,
            LastModifiedOn = DateTime.UtcNow,
            ProfessorComments = comments,
        };

        professorCommentDrafts[updateId] = string.Empty;
        await LoadTimelineAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task PersistAsync(string status, bool saveAsDraft, bool isAutosave)
    {
        if (MissingContext)
        {
            validationMessage = "Δεν εντοπίστηκε διπλωματική εργασία στη διεύθυνση. Προσθέστε thesisId και authorId στο URL.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.IsNullOrWhiteSpace(editorContent))
        {
            validationMessage = "Παρακαλούμε γράψτε μια ενημέρωση πριν την αποθήκευση.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (string.IsNullOrWhiteSpace(updateTitle))
        {
            validationMessage = "Παρακαλούμε προσθέστε τίτλο ενημέρωσης πριν την αποθήκευση.";
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            if (!isAutosave) isSaving = true;

            var now = DateTime.UtcNow;
            Guid? storedArtifactId = null;

            if (selectedAttachmentFile is not null && !isAutosave)
            {
                await using var fileStream = selectedAttachmentFile.OpenReadStream(MaxAttachmentSizeBytes);
                storedArtifactId = await ArtifactStorage.StoreAsync(
                    Session.UserName,
                    ResolvedThesisId,
                    selectedAttachmentFile.Name,
                    string.IsNullOrWhiteSpace(selectedAttachmentFile.ContentType) ? "application/zip" : selectedAttachmentFile.ContentType,
                    fileStream);
            }

            if (draftUpdateId.HasValue)
            {
                var idx = _store.FindIndex(u => u.Id == draftUpdateId.Value);
                if (idx >= 0)
                    _store[idx] = _store[idx] with
                    {
                        Title = updateTitle,
                        Status = status,
                        Note = editorContent,
                        LastModifiedOn = now,
                        AttachmentFileName = selectedAttachmentName,
                        AttachmentSizeBytes = selectedAttachmentSizeBytes,
                        ArtifactId = storedArtifactId ?? _store[idx].ArtifactId,
                    };
            }
            else
            {
                var newId = Guid.NewGuid();
                _store.Add(new ThesisUpdateTimelineDto(newId, ResolvedAuthorId, updateTitle, status, editorContent, now, now,
                    selectedAttachmentName, selectedAttachmentSizeBytes, storedArtifactId, Array.Empty<ProfessorCommentDto>()));
                if (saveAsDraft) draftUpdateId = newId;
            }

            if (saveAsDraft)
            {
                autosaveMessage = $"Αποθηκεύτηκε αυτόματα στις {DateTime.Now:HH:mm:ss}.";
            }
            else
            {
                draftUpdateId = null;
                autosaveMessage = null;
                updateTitle = string.Empty;
                editorContent = string.Empty;
                previewHtml = string.Empty;
                selectedAttachmentName = null;
                selectedAttachmentSizeBytes = null;
                selectedAttachmentFile = null;
            }

            validationMessage = null;
            await LoadTimelineAsync();
        }
        catch (Exception ex)
        {
            validationMessage = ex.Message;
        }
        finally
        {
            if (!isAutosave) isSaving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ScheduleAutosave()
    {
        CancelAndDisposeAutosaveCts();
        if (string.IsNullOrWhiteSpace(editorContent)) return;
        autosaveCts = new CancellationTokenSource();
        _ = AutosaveAsync(autosaveCts.Token);
    }

    private void CancelAndDisposeAutosaveCts()
    {
        if (autosaveCts is null)
        {
            return;
        }

        try
        {
            autosaveCts.Cancel();
        }
        catch (ObjectDisposedException)
        {
        }

        try
        {
            autosaveCts.Dispose();
        }
        catch (ObjectDisposedException)
        {
        }

        autosaveCts = null;
    }

    private async Task AutosaveAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(AutosaveDelayMilliseconds), token);
            await PersistAsync(ThesisUpdateStatuses.Draft, saveAsDraft: true, isAutosave: true);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private MarkupString PreviewMarkup => new(previewHtml);

    private static string FormatDate(DateTime timestamp) => timestamp.ToLocalTime()
        .ToString("dd MMM yyyy • HH:mm", CultureInfo.CurrentUICulture);

    private static bool WasEdited(ThesisUpdateTimelineDto item) =>
        Math.Abs((item.LastModifiedOn - item.OccurredOn).TotalMinutes) >= 1;

    private static string BuildSnippet(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
        {
            return "—";
        }

        var html = Markdown.ToHtml(markdown, MarkdownPipeline);
        var plain = Regex.Replace(html, "<[^>]+>", string.Empty);
        plain = WebUtility.HtmlDecode(plain).Trim();

        return plain.Length > 180 ? string.Concat(plain.AsSpan(0, 180), "…") : plain;
    }

    private static string StatusBadgeClass(string status) => status switch
    {
        var value when value.Equals(ThesisUpdateStatuses.UnderReview, StringComparison.OrdinalIgnoreCase) => "badge status-badge status-pending",
        var value when value.Equals(ThesisUpdateStatuses.Approved, StringComparison.OrdinalIgnoreCase) => "badge status-badge status-accepted",
        var value when value.Equals(ThesisUpdateStatuses.Draft, StringComparison.OrdinalIgnoreCase) => "badge status-badge status-draft",
        _ => "badge status-badge",
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var kilobytes = bytes / 1024d;
        if (kilobytes < 1024)
        {
            return $"{kilobytes:F1} KB";
        }

        var megabytes = kilobytes / 1024d;
        return $"{megabytes:F1} MB";
    }

    public void Dispose()
    {
        CancelAndDisposeAutosaveCts();
    }
}
