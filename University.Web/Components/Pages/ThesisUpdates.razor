            <div class="card-body">
                <p class="text-muted mb-0">This table will show the latest updates once the data layer is connected.</p>
            </div>
        </div>
    </section>

    <section>
        <h2 class="h4 fw-semibold mb-3">Upload Center</h2>
        <div class="card info-card">
            <div class="card-body">
                <p class="text-muted mb-0">File upload controls and validation messages will be added as implementation progresses.</p>
            </div>
        </div>
