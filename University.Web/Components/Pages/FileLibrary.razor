@page "/file-library"
@inject IStudentDashboardService DashboardService
@inject UserSessionService Session

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2"><span class="bi bi-folder2-open"></span> Library</span>
            <h1 class="section-heading mb-2">Thesis File Library</h1>
            <p class="text-muted mb-0">Centralized access to thesis resources, feedback records, and delivery links.</p>
        </div>
        <NavLink class="btn btn-outline-primary mt-3 mt-lg-0" href="@TimelineLink">Open timeline uploads</NavLink>
    </div>

    @if (isLoading)
    {
        <div class="card info-card">
            <div class="card-body text-muted">Loading file library...</div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-warning" role="alert">@loadError</div>
    }
    else
    {
        <div class="alert alert-info" role="status">
            <span class="bi bi-info-circle me-2"></span>
            This view reads persisted attachment metadata directly from thesis updates.
        </div>

        <section class="mb-4">
            <h2 class="h4 fw-semibold mb-3">Active Thesis Workspaces</h2>
            @if (dashboard.ActiveTheses.Count == 0)
            {
                <div class="card info-card">
                    <div class="card-body text-muted">No active thesis assignment is available yet.</div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var thesis in dashboard.ActiveTheses)
                    {
                        <div class="col-12 col-xl-6">
                            <div class="card info-card h-100">
                                <div class="card-body">
                                    <h3 class="h5 mb-2">@thesis.TopicTitle</h3>
                                    <p class="small text-muted mb-2">Status: @thesis.Status</p>
                                    <p class="small text-muted mb-3">Next milestone: @thesis.NextMilestoneDueOn.ToString("dd MMM yyyy")</p>
                                    <div class="d-flex flex-wrap gap-2">
                                        <NavLink class="btn btn-sm btn-outline-primary" href="@BuildTimelineLink(thesis.TopicId)">Timeline</NavLink>
                                        <NavLink class="btn btn-sm btn-outline-primary" href="@BuildMeetingsLink(thesis.TopicId)">Meetings</NavLink>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="mb-4">
            <h2 class="h4 fw-semibold mb-3">Files Uploaded</h2>
            <div class="card info-card">
                <div class="card-body">
                    @if (dashboard.FileLibraryRecords.Count == 0)
                    {
                        <p class="text-muted mb-0">No attachment metadata is stored yet. Upload a ZIP from Thesis Updates and publish it to appear here.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var file in dashboard.FileLibraryRecords)
                            {
                                <li class="list-group-item px-0">
                                    <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                        <strong>@file.FileName</strong>
                                        <span class="small text-muted">@FormatFileSize(file.FileSizeBytes)</span>
                                    </div>
                                    <div class="library-metadata mb-2">
                                        <div>
                                            <div class="label">Artifact ID</div>
                                            <div class="value">@file.ArtifactId</div>
                                        </div>
                                        <div>
                                            <div class="label">Uploaded</div>
                                            <div class="value">@file.UploadedOn.ToString("dd MMM yyyy")</div>
                                        </div>
                                        <div>
                                            <div class="label">Thesis ID</div>
                                            <div class="value">@file.ThesisId</div>
                                        </div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-3">
                                        <a class="small" href="@file.DownloadHref" download="@file.FileName">Download artifact</a>
                                        <NavLink class="small" href="@TimelineLink">Open in thesis timeline</NavLink>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </section>

        <section>
            <h2 class="h4 fw-semibold mb-3">Latest Feedback Records</h2>
            <div class="card info-card">
                <div class="card-body">
                    @if (dashboard.RecentComments.Count == 0)
                    {
                        <p class="text-muted mb-0">No feedback records yet. Publish updates to populate this section.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var record in dashboard.RecentComments)
                            {
                                <li class="list-group-item px-0">
                                    <div class="d-flex justify-content-between flex-wrap gap-2 mb-1">
                                        <strong>Update #@record.UpdateId feedback</strong>
                                        <span class="small text-muted">@record.CreatedOn.ToString("dd MMM yyyy")</span>
                                    </div>
                                    <p class="mb-1">@record.Message</p>
                                    <div class="small text-muted mb-1">Author: @record.Author</div>
                                    <NavLink class="small" href="@TimelineLink">Review in thesis timeline</NavLink>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </section>
    }
</div>

@code {
    private StudentDashboardData dashboard = StudentDashboardData.Empty;
    private bool isLoading = true;
    private string? loadError;

    [SupplyParameterFromQuery(Name = "thesisId")]
    public Guid ThesisId { get; set; }

    [SupplyParameterFromQuery(Name = "authorId")]
    public int? AuthorId { get; set; }

    private string TimelineLink
        => ThesisId == Guid.Empty || AuthorId is null
            ? "updates"
            : $"updates?thesisId={ThesisId}&authorId={AuthorId.Value}";

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || Session.Role != UserRole.Student)
        {
            isLoading = false;
            loadError = "Please sign in as a student to use the file library.";
            return;
        }

        dashboard = await DashboardService.GetDashboardAsync(Session.UserName);
        isLoading = false;
    }

    private string BuildTimelineLink(Guid topicId)
        => dashboard.StudentId is null
            ? "updates"
            : $"updates?thesisId={topicId}&authorId={dashboard.StudentId.Value}";

    private string BuildMeetingsLink(Guid topicId)
        => dashboard.StudentId is null
            ? "meetings"
            : $"meetings?thesisId={topicId}&authorId={dashboard.StudentId.Value}";

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        var kilobytes = bytes / 1024d;
        if (kilobytes < 1024)
        {
            return $"{kilobytes:F1} KB";
        }

        var megabytes = kilobytes / 1024d;
        return $"{megabytes:F1} MB";
    }
}