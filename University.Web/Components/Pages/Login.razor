@page "/login"
@layout LoginLayout
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject UserSessionService Session

<div class="login-page">
    <div class="login-card">

        @* ── Brand header ── *@
        <div class="login-brand">
            <div class="login-logo">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="48" height="48" rx="8" fill="#8c1116"/>
                    <path d="M24 10L38 17V22C38 30.837 31.732 39.026 24 41C16.268 39.026 10 30.837 10 22V17L24 10Z" fill="#d4c4a1" opacity="0.45"/>
                    <path d="M14 19.5L24 14L34 19.5V24C34 30.627 29.523 36.82 24 38.5C18.477 36.82 14 30.627 14 24V19.5Z" fill="white" opacity="0.15"/>
                    <text x="24" y="28" text-anchor="middle" fill="white" font-size="14" font-family="Manrope, Open Sans, sans-serif" font-weight="700">TC</text>
                </svg>
            </div>
            <h1 class="login-title">Σύστημα Διαχείρισης Διπλωματικών Εργασιών</h1>
            <p class="login-subtitle">Συνδεθείτε για να συνεχίσετε</p>
        </div>

        @* ── Login Form ── *@
        <div class="login-form">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @errorMessage
                </div>
            }

            <div class="mb-3">
                <label for="email" class="login-label">Email</label>
                <input type="email" class="login-input w-100" id="email" placeholder="student1@univ.edu" @bind="email" />
            </div>

            <div class="mb-3">
                <label for="password" class="login-label">Κωδικός</label>
                <input type="password" class="login-input w-100" id="password" placeholder="TempPass123!" @bind="password" />
            </div>

            <button class="btn btn-login w-100 mt-4" @onclick="HandleLogin">Σύνδεση</button>
            <a class="login-help-link d-inline-block mt-3" href="#">Ξεχάσατε τον κωδικό σας;</a>
        </div>

        @* ── Test Credentials ── *@
        <div class="login-demo mt-4">
            <strong>Δοκιμαστικά Στοιχεία</strong> &mdash; Κωδικός: <code>TempPass123!</code>
            <table class="mt-2 w-100" style="font-size:0.82rem;border-collapse:collapse">
                <thead>
                    <tr style="border-bottom:1px solid #ccc">
                        <th style="padding:2px 8px 4px 0;text-align:left">Ρόλος</th>
                        <th style="padding:2px 8px 4px 0;text-align:left">Email</th>
                        <th style="padding:2px 0 4px 0;text-align:left">Όνομα</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td style="padding:2px 8px 2px 0">Φοιτητής</td><td style="padding:2px 8px 2px 0">student1@univ.edu</td><td>&mdash;</td></tr>
                    <tr style="border-top:1px solid #eee"><td style="padding:4px 8px 2px 0">Καθηγητής</td><td style="padding:4px 8px 2px 0">prof1@univ.edu</td><td>Επίκ. Χριστοδούλου</td></tr>
                    <tr><td></td><td style="padding:2px 8px 2px 0">prof2@univ.edu</td><td>Αναπλ. Πετρέλλης</td></tr>
                    <tr><td></td><td style="padding:2px 8px 2px 0">prof3@univ.edu</td><td>Επίκ. Χαραλαμπάκος</td></tr>
                    <tr><td></td><td style="padding:2px 8px 2px 0">prof4@univ.edu</td><td>Αναπλ. Κούτρας</td></tr>
                    <tr><td></td><td style="padding:2px 8px 2px 0">prof5@univ.edu</td><td>Αναπλ. Τζήμας</td></tr>
                </tbody>
            </table>
        </div>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    protected override void OnInitialized()
    {
        // Already authenticated users redirect to dashboard
        // No authentication check needed here on initial load
    }

    private async Task HandleLogin()
    {
        errorMessage = "";

        var result = await JS.InvokeAsync<LoginApiResponse>("thesisAuth.login", email, password);

        if (result.Success)
        {
            if (!Enum.TryParse<UserRole>(result.Role, ignoreCase: true, out var sessionRole))
            {
                errorMessage = "Δεν ήταν δυνατός ο προσδιορισμός του ρόλου.";
                return;
            }

            Session.Login(email, sessionRole);

            var redirectUrl = string.Equals(result.Role, "Professor", StringComparison.OrdinalIgnoreCase)
                ? "/"
                : "/dashboard";
            Nav.NavigateTo(redirectUrl, forceLoad: false);
        }
        else
        {
            errorMessage = result.Message ?? "Αποτυχία σύνδεσης";
        }
    }

    private sealed class LoginApiResponse
    {
        public bool Success { get; set; }
        public string? Role { get; set; }
        public string? Message { get; set; }
    }
}
