@page "/login"
@layout LoginLayout
@inject UserSessionService Session
@inject NavigationManager Nav

<div class="login-page">
    <div class="login-card">

        @* ── Brand header ── *@
        <div class="login-brand">
            <div class="login-logo">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="48" height="48" rx="12" fill="#0b4f75"/>
                    <path d="M24 10L38 17V22C38 30.837 31.732 39.026 24 41C16.268 39.026 10 30.837 10 22V17L24 10Z" fill="#4aa3df" opacity="0.35"/>
                    <path d="M14 19.5L24 14L34 19.5V24C34 30.627 29.523 36.82 24 38.5C18.477 36.82 14 30.627 14 24V19.5Z" fill="white" opacity="0.15"/>
                    <text x="24" y="28" text-anchor="middle" fill="white" font-size="14" font-family="Open Sans, sans-serif" font-weight="700">TC</text>
                </svg>
            </div>
            <h1 class="login-title">Thesis Collaboration</h1>
            <p class="login-subtitle">Επιλέξτε τον ρόλο σας για να συνεχίσετε</p>
        </div>

        @* ── Role cards ── *@
        <div class="row g-3">

            <div class="col-6">
                <button class="role-card h-100" @onclick='() => SelectAndLogin(UserRole.Student)'>
                    <div class="role-card__icon role-card__icon--student">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </div>
                    <div class="role-card__label">Φοιτητής</div>
                    <div class="role-card__sub">Student</div>
                </button>
            </div>

            <div class="col-6">
                <button class="role-card h-100" @onclick='() => SelectAndLogin(UserRole.Professor)'>
                    <div class="role-card__icon role-card__icon--professor">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H2zm6 3a3 3 0 1 1 0 6A3 3 0 0 1 8 4zm0 7c-2.796 0-5 1.343-5 3h10c0-1.657-2.204-3-5-3z"/>
                        </svg>
                    </div>
                    <div class="role-card__label">Καθηγητής</div>
                    <div class="role-card__sub">Professor</div>
                </button>
            </div>

        </div>

    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
            Nav.NavigateTo("/");
    }

    private void SelectAndLogin(UserRole role)
    {
        Session.Login(role == UserRole.Student ? "Student" : "Professor", role);
        Nav.NavigateTo("/");
    }
}
