@page "/assignments"
@using System.Globalization

<div class="container page-section">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between mb-4">
        <div>
            <span class="highlight-tag mb-2">
                <span class="bi bi-people-fill"></span>
                Supervisor Workflow
            </span>
            <h1 class="section-heading mb-2">Supervisor Assignment</h1>
            <p class="text-muted mb-0">
                Επιλέξτε φοιτητές και επιβλέποντες, ελέγξτε τα τρέχοντα δικαιώματα πρόσβασης και
                στείλτε ειδοποιήσεις όταν ολοκληρώνετε μια νέα αντιστοίχιση.
            </p>
        </div>
        <button class="btn btn-primary mt-3 mt-lg-0" @onclick="OpenConfirmModal" disabled="@(SelectedStudent is null || SelectedSupervisor is null)">
            Συνέχεια με την αντιστοίχιση
        </button>
    </div>

    <div class="row g-4">
        <div class="col-xl-4">
            <div class="card selection-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">1. Επιλογή Φοιτητή</h2>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white"><span class="bi bi-search"></span></span>
                        <input class="form-control" placeholder="Αναζήτηση φοιτητή" @bind="studentSearch" />
                    </div>
                    <div class="assignment-list">
                        @foreach (var student in FilteredStudents)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action assignment-item @(student.Id == SelectedStudent?.Id ? "active" : null)"
                                    @onclick="() => SelectStudent(student)">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@student.DisplayName</div>
                                        <small class="text-muted">@student.Email</small>
                                    </div>
                                    <span class="badge bg-light text-dark">@student.Department</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card selection-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">2. Επιλογή Επιβλέποντα</h2>
                    <div class="input-group mb-3">
                        <span class="input-group-text bg-white"><span class="bi bi-search"></span></span>
                        <input class="form-control" placeholder="Αναζήτηση επιβλέποντα" @bind="supervisorSearch" />
                    </div>
                    <div class="assignment-list">
                        @foreach (var supervisor in FilteredSupervisors)
                        {
                            <button type="button"
                                    class="list-group-item list-group-item-action assignment-item @(supervisor.Id == SelectedSupervisor?.Id ? "active" : null)"
                                    @onclick="() => SelectSupervisor(supervisor)">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@supervisor.DisplayName</div>
                                        <small class="text-muted">@supervisor.Email</small>
                                    </div>
                                    <span class="badge bg-light text-dark">@supervisor.Department</span>
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card info-card h-100">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">3. Επισκόπηση Αντιστοίχισης</h2>
                    <div class="mb-4">
                        <div class="d-flex gap-2 align-items-center mb-2">
                            <span class="badge bg-info-subtle text-info-emphasis">
                                <span class="bi bi-person"></span>
                            </span>
                            <div>
                                <div class="small text-muted">Επιλεγμένος Φοιτητής</div>
                                <div class="fw-semibold">@(SelectedStudent?.DisplayName ?? "Καμία επιλογή")</div>
                            </div>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="badge bg-success-subtle text-success-emphasis">
                                <span class="bi bi-mortarboard"></span>
                            </span>
                            <div>
                                <div class="small text-muted">Επιλεγμένος Επιβλέπων</div>
                                <div class="fw-semibold">@(SelectedSupervisor?.DisplayName ?? "Καμία επιλογή")</div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info d-flex align-items-start gap-2" role="alert">
                        <span class="bi bi-info-circle-fill mt-1"></span>
                        <div>
                            Όταν επιβεβαιώσετε την αντιστοίχιση, το σύστημα θα ενημερώσει τα δικαιώματα πρόσβασης και θα
                            στείλει οδηγίες συνεργασίας στους συμμετέχοντες.
                        </div>
                    </div>

                    <h3 class="h6 text-uppercase text-muted mt-4">Ιστορικό Πρόσφατων Αντιστοιχίσεων</h3>
                    <ul class="list-unstyled mb-0 mt-3">
                        @foreach (var entry in recentAssignments)
                        {
                            <li class="recent-assignment-entry">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">@entry.StudentName → @entry.SupervisorName</div>
                                        <small class="text-muted">@entry.ThesisTitle</small>
                                    </div>
                                    <span class="badge bg-light text-dark">@entry.AssignedAt.ToString("dd MMM", CultureInfo.CurrentUICulture)</span>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="section-divider"></div>

    <section class="card info-card">
        <div class="card-body">
            <div class="d-flex flex-column flex-lg-row gap-4 align-items-lg-center justify-content-between">
                <div>
                    <h2 class="h5 fw-semibold mb-2">Οδηγός Διαχείρισης Πρόσβασης</h2>
                    <p class="mb-0 text-muted">
                        Για κάθε νέα αντιστοίχιση, φροντίστε να ενημερώσετε τους συμμετέχοντες σχετικά με τις υποχρεώσεις
                        τους και τη διαδικασία κοινής χρήσης αρχείων στη διπλωματική εργασία.
                    </p>
                </div>
                <div class="d-flex gap-3">
                    <button class="btn btn-outline-primary" @onclick="CopyAccessInstructions">
                        <span class="bi bi-clipboard-check"></span>
                        Αντιγραφή οδηγιών
                    </button>
                    <button class="btn btn-outline-secondary" @onclick="ResetSelection">
                        <span class="bi bi-arrow-counterclockwise"></span>
                        Επαναφορά επιλογών
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(notificationMessage))
            {
                <div class="alert alert-success mt-4" role="alert">
                    <span class="bi bi-check-circle-fill me-2"></span>
                    @notificationMessage
                </div>
            }
        </div>
    </section>
</div>

@if (showConfirmation)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(8, 26, 45, 0.35);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Επιβεβαίωση αντιστοίχισης</h5>
                    <button type="button" class="btn-close" @onclick="CloseConfirmModal" aria-label="Κλείσιμο"></button>
                </div>
                <div class="modal-body">
                    <p>
                        Θα δημιουργηθεί ιδιωτικός χώρος διπλωματικής για τον φοιτητή <strong>@SelectedStudent?.DisplayName</strong>
                        με επιβλέποντα <strong>@SelectedSupervisor?.DisplayName</strong>.
                    </p>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><span class="bi bi-shield-check me-2 text-success"></span>Ενημέρωση δικαιωμάτων πρόσβασης</li>
                        <li class="list-group-item"><span class="bi bi-envelope-paper-heart me-2 text-success"></span>Αποστολή email οδηγιών</li>
                        <li class="list-group-item"><span class="bi bi-clock-history me-2 text-success"></span>Καταγραφή στο audit log του τμήματος</li>
                    </ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseConfirmModal">Άκυρο</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmAssignment">Επιβεβαίωση</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private readonly List<UserOption> students =
    [
        new(Guid.Parse("5b14d7b4-8e8a-4a60-9e43-6c5851a02680"), "Αντωνίου Μαρία", "maria.antoniou@uop.gr", "ΗΜΜΥ"),
        new(Guid.Parse("5e6e6e9a-410a-4587-9c61-3872a4bfb30b"), "Γεωργίου Νίκος", "nikos.georgiou@uop.gr", "ΠΛΗΡΟΦ"),
        new(Guid.Parse("8d7a8d69-18d7-40af-8d07-94fb2d6d40e0"), "Δημητρίου Ελένη", "eleni.dimitriou@uop.gr", "ΗΜΜΥ"),
        new(Guid.Parse("d01b0c3c-0f2e-4f0f-9661-813b9a7a5135"), "Ζαχαριάς Πέτρος", "petros.zacharias@uop.gr", "ΠΛΗΡΟΦ"),
        new(Guid.Parse("a2c78ab0-2e9c-4ef5-8c32-5c0ad84d8b9e"), "Θεοδώρου Άννα", "anna.theodorou@uop.gr", "ΗΜΜΥ"),
    ];

    private readonly List<UserOption> supervisors =
    [
        new(Guid.Parse("f1f09504-7a92-4e8f-9f1c-6b1d6949a0c0"), "Καθηγητής Λάμπρου", "klabrou@uop.gr", "Ενέργεια"),
        new(Guid.Parse("fb39dd9b-d532-4f4a-9b36-a8b5eecade36"), "Αναπ. Καθηγήτρια Σταθοπούλου", "stathopoulou@uop.gr", "Τηλεπικοινωνίες"),
        new(Guid.Parse("0e9ad253-579f-4a7c-92df-c6d0c6f06788"), "Επικ. Καθηγητής Παπαδόπουλος", "papadopoulos@uop.gr", "Συστήματα"),
        new(Guid.Parse("266f45b3-5ee2-40e3-8098-e6e03641726a"), "Λέκτορας Μανιάτη", "maniati@uop.gr", "Λογισμικό"),
    ];

    private readonly List<RecentAssignmentEntry> recentAssignments =
    [
        new("Αλεξίου Μελίνα", "Καθηγητής Λάμπρου", "Ανάλυση φορτίων μικροδικτύων", DateTime.UtcNow.AddDays(-2)),
        new("Παπαγιαννίδης Χάρης", "Αναπ. Καθηγήτρια Σταθοπούλου", "Συστήματα επικοινωνίας IoT", DateTime.UtcNow.AddDays(-4)),
        new("Σωτηρίου Κωνσταντίνα", "Λέκτορας Μανιάτη", "Εφαρμογές AI σε έξυπνα δίκτυα", DateTime.UtcNow.AddDays(-6)),
    ];

    private string studentSearch = string.Empty;
    private string supervisorSearch = string.Empty;
    private UserOption? SelectedStudent;
    private UserOption? SelectedSupervisor;
    private string notificationMessage = string.Empty;
    private bool showConfirmation;

    private IEnumerable<UserOption> FilteredStudents => students
        .Where(student => string.IsNullOrWhiteSpace(studentSearch)
            || student.DisplayName.Contains(studentSearch, StringComparison.OrdinalIgnoreCase)
            || student.Email.Contains(studentSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(student => student.DisplayName);

    private IEnumerable<UserOption> FilteredSupervisors => supervisors
        .Where(supervisor => string.IsNullOrWhiteSpace(supervisorSearch)
            || supervisor.DisplayName.Contains(supervisorSearch, StringComparison.OrdinalIgnoreCase)
            || supervisor.Email.Contains(supervisorSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(supervisor => supervisor.DisplayName);

    private void SelectStudent(UserOption student)
    {
        SelectedStudent = student;
        notificationMessage = string.Empty;
    }

    private void SelectSupervisor(UserOption supervisor)
    {
        SelectedSupervisor = supervisor;
        notificationMessage = string.Empty;
    }

    private void ResetSelection()
    {
        SelectedStudent = null;
        SelectedSupervisor = null;
        studentSearch = string.Empty;
        supervisorSearch = string.Empty;
        notificationMessage = string.Empty;
    }

    private void CopyAccessInstructions()
    {
        notificationMessage = "Οι οδηγίες πρόσβασης αντιγράφηκαν στο πρόχειρο (placeholder).";
    }

    private void OpenConfirmModal()
    {
        if (SelectedStudent is not null && SelectedSupervisor is not null)
        {
            showConfirmation = true;
            notificationMessage = string.Empty;
        }
    }

    private void CloseConfirmModal()
    {
        showConfirmation = false;
    }

    private void ConfirmAssignment()
    {
        if (SelectedStudent is null || SelectedSupervisor is null)
        {
            return;
        }

        recentAssignments.Insert(0, new RecentAssignmentEntry(
            SelectedStudent.DisplayName,
            SelectedSupervisor.DisplayName,
            "Νέο θέμα διπλωματικής (placeholder)",
            DateTime.UtcNow));

        notificationMessage = $"Η αντιστοίχιση ολοκληρώθηκε. Στάλθηκαν ειδοποιήσεις σε {SelectedStudent.DisplayName} και {SelectedSupervisor.DisplayName}.";

        showConfirmation = false;
    }

    private sealed record UserOption(Guid Id, string DisplayName, string Email, string Department);

    private sealed record RecentAssignmentEntry(string StudentName, string SupervisorName, string ThesisTitle, DateTime AssignedAt);
}