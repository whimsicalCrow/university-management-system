@inject UserSessionService Session
@inject NavigationManager Nav
@inject IThesisNotificationService NotifService
@implements IDisposable

<nav class="navbar navbar-expand-lg site-navbar navbar-dark" aria-label="Main navigation">
    <div class="container">
        <a class="navbar-brand" href="">Σύστημα Διαχείρισης Διπλωματικών</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="@(!Session.IsAuthenticated ? "/" : Session.Role == UserRole.Student ? "dashboard" : "")" Match="NavLinkMatch.All">Αρχική</NavLink>
                </li>

                @* ── Student-only links ── *@
                @if (Session.Role == UserRole.Student)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="thesis-topics">Θέματα Διπλωματικής</NavLink>
                    </li>
                }

                @* ── Shared links ── *@
                <li class="nav-item">
                    <NavLink class="nav-link" href="updates">Ενημερώσεις</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="meetings">Συναντήσεις</NavLink>
                </li>

                @* ── Professor-only links ── *@
                @if (Session.Role == UserRole.Professor)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="thesis-topics">Θέματα Διπλωματικής</NavLink>
                    </li>
                }
            </ul>

            @* ── CTA + user info + logout ── *@
            <div class="d-flex align-items-center gap-2 ms-lg-3">
                @if (Session.Role == UserRole.Professor)
                {
                    <a class="btn btn-outline-light btn-sm" href="thesis-topics">Πρόταση Θέματος</a>

                    <a class="position-relative nav-bell" href="/" title="Ειδοποιήσεις">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zM8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5.002 5.002 0 0 1 13 6c0 .88.32 4.2 1.22 6z"/>
                        </svg>
                        @if (_unreadCount > 0)
                        {
                            <span class="nav-bell-badge">@(_unreadCount > 9 ? "9+" : _unreadCount.ToString())</span>
                        }
                    </a>
                }

                <div class="nav-user-badge">
                    <span class="nav-user-role @(Session.Role == UserRole.Professor ? "nav-user-role--prof" : "nav-user-role--student")">
                        @(Session.Role == UserRole.Student ? "Φοιτητής" : "Καθ.")
                    </span>
                    <span class="nav-user-name">@Session.UserName</span>
                </div>

                <button class="btn btn-link nav-logout" title="Αποσύνδεση" @onclick="Logout">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                        <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</nav>

@code {
    private int _unreadCount;

    protected override async Task OnInitializedAsync()
    {
        Session.OnChange += HandleSessionChange;
        NotifService.Changed += HandleNotifChanged;
        await RefreshUnreadCountAsync();
    }

    private void HandleSessionChange()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadCountAsync();
            StateHasChanged();
        });
    }

    private void HandleNotifChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshUnreadCountAsync();
            StateHasChanged();
        });
    }

    private async Task RefreshUnreadCountAsync()
    {
        _unreadCount = (Session.Role == UserRole.Professor && Session.UserName is not null)
            ? await NotifService.GetUnreadCountAsync(Session.UserName)
            : 0;
    }

    private void Logout()
    {
        Session.Logout();
        Nav.NavigateTo("/auth/logout", forceLoad: true);
    }

    public void Dispose()
    {
        Session.OnChange -= HandleSessionChange;
        NotifService.Changed -= HandleNotifChanged;
    }
}
