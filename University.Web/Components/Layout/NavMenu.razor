@inject UserSessionService Session
@inject NavigationManager Nav
@implements IDisposable

<nav class="navbar navbar-expand-lg site-navbar navbar-dark" aria-label="Main navigation">
    <div class="container">
        <a class="navbar-brand" href="">Thesis Collaboration</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <NavLink class="nav-link" href="@(Session.Role == UserRole.Student ? "dashboard" : "")" Match="NavLinkMatch.All">Αρχική</NavLink>
                </li>

                @* ── Student-only links ── *@
                @if (Session.Role == UserRole.Student)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="thesis-topics">Thesis Topics</NavLink>
                    </li>
                }

                @* ── Shared links ── *@
                <li class="nav-item">
                    <NavLink class="nav-link" href="updates">Thesis Updates</NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="meetings">Meetings</NavLink>
                </li>

                @* ── Professor-only links ── *@
                @if (Session.Role == UserRole.Professor)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="assignments">Supervisor Workflow</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="thesis-topics">Thesis Topics</NavLink>
                    </li>
                }
            </ul>

            @* ── CTA + user info + logout ── *@
            <div class="d-flex align-items-center gap-2 ms-lg-3">
                @if (Session.Role == UserRole.Professor)
                {
                    <a class="btn btn-outline-light btn-sm" href="thesis-topics">Propose Topic</a>
                }

                <div class="nav-user-badge">
                    <span class="nav-user-role @(Session.Role == UserRole.Professor ? "nav-user-role--prof" : "nav-user-role--student")">
                        @(Session.Role == UserRole.Student ? "Student" : "Prof")
                    </span>
                    <span class="nav-user-name">@Session.UserName</span>
                </div>

                <button class="btn btn-link nav-logout" title="Logout" @onclick="Logout">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                        <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</nav>

@code {
    protected override void OnInitialized()
    {
        Session.OnChange += StateHasChanged;
    }

    private void Logout()
    {
        Session.Logout();
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
    }
}
