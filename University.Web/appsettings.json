{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "UniversityDatabase": "Server=(localdb)\\mssqllocaldb;Database=UniversityCollaborationDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "AllowedHosts": "*",
  "Attachments": {
    "StorageProvider": "Local",
    "LocalStoragePath": "attachments",
    "MaxFileSizeBytes": 20971520,
    "AllowedExtensions": [ ".pdf", ".docx", ".pptx", ".zip" ],
    "DownloadTokenExpiryMinutes": 15
  }
}
